@dataclass(frozen=True)
class BaseMap:
    path: Path
    bbox: dict[str, float]           # terrain coverage
    topology_bbox: "dict | None"     # topology coverage, None = no shapefile data


@dataclass(frozen=True)
class SourceTile:
    name: str
    bbox: dict[str, float]


def xcm_terrain_bbox(xcm: Path):
    with zipfile.ZipFile(xcm) as zf, tempfile.TemporaryDirectory(
        prefix="kigo_task_map_base_"
    ) as tmp:
        zf.extract("terrain.j2w", tmp)
        zf.extract("terrain.jp2", tmp)
        world_path = Path(tmp) / "terrain.j2w"
        terrain_path = Path(tmp) / "terrain.jp2"

        a, d, b, e, c, f = crop.read_world(world_path)
        if abs(b) > 1e-12 or abs(d) > 1e-12 or a <= 0 or e >= 0:
            raise ValueError("only north-up terrain.j2w files are supported")

        width, height = crop.image_size(terrain_path)

    west = c - a / 2.0
    east = west + a * width
    north = f - e / 2.0
    south = north + e * height
    return {"south": south, "west": west, "north": north, "east": east}


def find_base_maps(configured) -> tuple[BaseMap, ...]:
    candidates = []
    if configured is not None:
        candidates.append(configured)

    env_path = os.environ.get("KIGO_TASK_MAP_BASE_XCM")
    if env_path:
        candidates.append(Path(env_path))

    candidates.extend(Path(path) for path in BASE_MAP_CANDIDATES)
    seen = set()
    base_maps = []
    for candidate in candidates:
        if candidate in seen:
            continue
        seen.add(candidate)
        if candidate.exists():
            terrain_bbox = xcm_terrain_bbox(candidate)
            topology_bbox = crop.xcm_topology_bbox(candidate)
            base_maps.append(BaseMap(candidate, terrain_bbox, topology_bbox))

    if base_maps:
        return tuple(base_maps)

    raise FileNotFoundError(
        "No base XCM map found. Set --base-xcm or KIGO_TASK_MAP_BASE_XCM."
    )


def number(value, name: str) -> float:
    if isinstance(value, bool) or not isinstance(value, (int, float)):
        raise ValueError(f"{name} must be a number")
    return float(value)


def task_map_margin_km(payload) -> float:
    margin = number(payload.get("margin_km", TASK_MAP_MARGIN_KM), "margin_km")
    if margin <= 0:
        raise ValueError("margin_km must be positive")

    return max(TASK_MAP_MARGIN_KM, margin)


def bbox_from_dict(bbox_dict):
    if not isinstance(bbox_dict, dict):
        raise ValueError("bbox must be an object")

    return {
        "south": number(bbox_dict.get("south"), "bbox.south"),
        "west": number(bbox_dict.get("west"), "bbox.west"),
        "north": number(bbox_dict.get("north"), "bbox.north"),
        "east": number(bbox_dict.get("east"), "bbox.east"),
    }


def task_points_from_payload(payload):
    points = payload.get("points")
    if not isinstance(points, list):
        return []

    crop_points = []
    for index, point in enumerate(points):
        if not isinstance(point, dict):
            raise ValueError(f"points[{index}] must be an object")
        name = str(point.get("name") or point.get("role") or f"TP{index + 1:03d}")
        lat = number(point.get("lat"), f"points[{index}].lat")
        lon = number(point.get("lon"), f"points[{index}].lon")
        crop_points.append((name, lat, lon))

    return crop_points


def bbox_and_segments_from_payload(payload):
    """Return (bbox, corridor_segments) from payload.

    When a bbox is supplied, it is authoritative.  The posted points are kept
    for audit/logging and for older clients that only send point lists.
    """
    bbox_dict = payload.get("bbox")
    if isinstance(bbox_dict, dict):
        return bbox_from_dict(bbox_dict), []

    crop_points = task_points_from_payload(payload)
    if len(crop_points) >= 2:
        bbox = crop.buffered_bbox(crop_points, task_map_margin_km(payload))
        return bbox, crop.route_segments(crop_points)

    raise ValueError("payload must contain at least two points or bbox")


def bbox_from_payload(payload):
    bbox, _ = bbox_and_segments_from_payload(payload)
    return bbox


def route_cache_bbox(payload, request_bbox, task_points):
    if len(task_points) >= 2:
        return crop.buffered_bbox(task_points, TASK_MAP_ROUTE_TILE_MARGIN_KM)
    return request_bbox


def payload_point_count(payload) -> int:
    points = payload.get("points")
    return len(points) if isinstance(points, list) else 0


def payload_points_summary(payload) -> str:
    points = payload.get("points")
    if not isinstance(points, list):
        return ""

    parts = []
    for index, point in enumerate(points):
        if not isinstance(point, dict):
            parts.append(f"{index}:<invalid>")
            continue
        role = str(point.get("role") or index)
        name = str(point.get("name") or "")
        lat = point.get("lat")
        lon = point.get("lon")
        try:
            parts.append(f"{role}:{name}@{float(lat):.8f},{float(lon):.8f}")
        except (TypeError, ValueError):
            parts.append(f"{role}:{name}@<invalid>")

    return "; ".join(parts)


def runway_label(tags) -> str:
    if not isinstance(tags, dict):
        return ""
    return str(tags.get("ref") or tags.get("name") or "")


def runway_width_m(tags) -> float:
    if isinstance(tags, dict):
        raw_width = tags.get("width") or tags.get("est_width")
        if raw_width is not None:
            text = str(raw_width).strip().lower().replace(",", ".")
            if text.endswith("m"):
                text = text[:-1].strip()
            try:
                width = float(text)
                if 1 <= width <= 200:
                    return width
            except ValueError:
                pass

    return 45.0


def osm_runway_query(bbox):
    query_timeout = max(20, int(TASK_MAP_OVERPASS_TIMEOUT_S))
    return (
        f"[out:json][timeout:{query_timeout}];"
        f'way["aeroway"="runway"]({bbox["south"]:.8f},{bbox["west"]:.8f},'
        f'{bbox["north"]:.8f},{bbox["east"]:.8f});'
        "out geom;"
    )


def fetch_osm_runways(bbox):
    cached = load_cached_runways(bbox)
    if cached is not None:
        return cached, "", "cache"

    try:
        features = fetch_osm_runways_from_overpass(bbox)
    except Exception as exc:
        cached = load_cached_runways(bbox)
        if cached is not None:
            return cached, str(exc), "cache-after-error"
        raise

    save_cached_runways(bbox, features)
    return features, "", "overpass"


def fetch_osm_runways_from_overpass(bbox):
    query = osm_runway_query(bbox)
    data = urllib.parse.urlencode({"data": query}).encode("utf-8")
    last_error = None
    payload = None
    attempts = max(1, TASK_MAP_OVERPASS_ATTEMPTS)
    for _ in range(attempts):
        for url in TASK_MAP_OVERPASS_URLS:
            request = urllib.request.Request(
                url,
                data=data,
                headers={
                    "Content-Type": "application/x-www-form-urlencoded",
                    "User-Agent": "Kigo task map runway fetcher",
                },
            )
            try:
                with urllib.request.urlopen(
                    request,
                    timeout=TASK_MAP_OVERPASS_TIMEOUT_S,
                ) as response:
                    payload = json.loads(response.read().decode("utf-8"))
                break
            except Exception as exc:
                last_error = exc
        if payload is not None:
            break

    if payload is None:
        raise last_error or RuntimeError("no Overpass endpoints configured")

    features = []
    seen = set()
    for element in payload.get("elements", []):
        if not isinstance(element, dict):
            continue
        tags = element.get("tags") or {}
        if tags.get("aeroway") != "runway":
            continue

        points = []
        for point in element.get("geometry") or ():
            if not isinstance(point, dict):
                continue
            lat = point.get("lat")
            lon = point.get("lon")
            if isinstance(lat, (int, float)) and isinstance(lon, (int, float)):
                points.append((float(lon), float(lat)))

        if len(points) < 2:
            continue

        key = tuple((round(lon, 7), round(lat, 7)) for lon, lat in points)
        if key in seen:
            continue
        seen.add(key)
        features.append(
            {
                "label": runway_label(tags),
                "points": points,
                "width_m": runway_width_m(tags),
            }
        )

    return features


def runway_cache_key(bbox):
    text = (
        f"{bbox['south']:.4f},{bbox['west']:.4f},"
        f"{bbox['north']:.4f},{bbox['east']:.4f}"
    )
    return hashlib.sha1(text.encode("ascii")).hexdigest()


def runway_feature_bbox(feature):
    points = feature.get("points") if isinstance(feature, dict) else None
    if not points:
        return None

    lons = [float(point[0]) for point in points]
    lats = [float(point[1]) for point in points]
    return {
        "south": min(lats),
        "west": min(lons),
        "north": max(lats),
        "east": max(lons),
    }


def feature_intersects_bbox(feature, bbox):
    feature_box = runway_feature_bbox(feature)
    if feature_box is None:
        return False
    return not (
        feature_box["east"] < bbox["west"]
        or feature_box["west"] > bbox["east"]
        or feature_box["north"] < bbox["south"]
        or feature_box["south"] > bbox["north"]
    )


def filter_runways_to_bbox(features, bbox):
    return [
        feature
        for feature in features or ()
        if feature_intersects_bbox(feature, bbox)
    ]


def normalise_cached_features(raw):
    features = []
    for feature in raw or ():
        if not isinstance(feature, dict):
            continue
        points = []
        for point in feature.get("points") or ():
            try:
                lon, lat = point
            except Exception:
                continue
            points.append((float(lon), float(lat)))
        if len(points) < 2:
            continue
        features.append(
            {
                "label": str(feature.get("label") or ""),
                "points": points,
                "width_m": float(feature.get("width_m") or 45.0),
            }
        )
    return features


def load_cached_runways(bbox):
    cache_dir = TASK_MAP_RUNWAY_CACHE_DIR
    exact = cache_dir / f"{runway_cache_key(bbox)}.json"
    candidates = [exact]
    if cache_dir.exists():
        candidates.extend(
            path
            for path in sorted(cache_dir.glob("*.json"))
            if path != exact
        )

    for path in candidates:
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
            cached_bbox = payload.get("bbox")
            if not isinstance(cached_bbox, dict):
                continue
            if not bbox_contains(cached_bbox, bbox):
                continue
            return filter_runways_to_bbox(
                normalise_cached_features(payload.get("features")),
                bbox,
            )
        except Exception:
            continue

    return None


def save_cached_runways(bbox, features):
    try:
        TASK_MAP_RUNWAY_CACHE_DIR.mkdir(parents=True, exist_ok=True)
        payload = {
            "bbox": bbox,
            "features": [
                {
                    "label": feature.get("label") or "",
                    "points": feature.get("points") or [],
                    "width_m": feature.get("width_m") or 45.0,
                }
                for feature in features or ()
            ],
        }
        path = TASK_MAP_RUNWAY_CACHE_DIR / f"{runway_cache_key(bbox)}.json"
        path.write_text(json.dumps(payload, separators=(",", ":")), encoding="utf-8")
    except Exception:
        pass


def runway_centerline_points(feature):
    points = feature.get("points") or []
    if len(points) < 2:
        return None

    origin_lon = points[0][0]
    origin_lat = points[0][1]
    mean_lat = sum(point[1] for point in points) / len(points)
    meters_per_lat = 111320.0
    meters_per_lon = max(1.0, meters_per_lat * math.cos(math.radians(mean_lat)))
    xy = [
        (
            (lon - origin_lon) * meters_per_lon,
            (lat - origin_lat) * meters_per_lat,
        )
        for lon, lat in points
    ]

    closed = len(points) >= 4 and points[0] == points[-1]
    if closed:
        ring = xy[:-1]
        if len(ring) < 3:
            return None

        best = None
        for index, start in enumerate(ring):
            end = ring[(index + 1) % len(ring)]
            dx = end[0] - start[0]
            dy = end[1] - start[1]
            length = math.hypot(dx, dy)
            if best is None or length > best[0]:
                best = (length, dx, dy)

        if best is None or best[0] <= 0:
            return None

        length, dx, dy = best
        ux = dx / length
        uy = dy / length
        px = -uy
        py = ux
        axis_values = [x * ux + y * uy for x, y in ring]
        side_values = [x * px + y * py for x, y in ring]
        axis_min = min(axis_values)
        axis_max = max(axis_values)
        side_center = (min(side_values) + max(side_values)) / 2.0
        start_xy = (
            ux * axis_min + px * side_center,
            uy * axis_min + py * side_center,
        )
        end_xy = (
            ux * axis_max + px * side_center,
            uy * axis_max + py * side_center,
        )
    else:
        start_xy = xy[0]
        end_xy = xy[-1]

    if math.hypot(end_xy[0] - start_xy[0], end_xy[1] - start_xy[1]) <= 0:
        return None

    return [
        (
            origin_lon + start_xy[0] / meters_per_lon,
            origin_lat + start_xy[1] / meters_per_lat,
        ),
        (
            origin_lon + end_xy[0] / meters_per_lon,
            origin_lat + end_xy[1] / meters_per_lat,
        ),
    ]


def runway_centerline_feature(feature):
    points = runway_centerline_points(feature)
    if points is None:
        return None
    return {
        "label": feature.get("label") or "",
        "points": points,
        "width_m": feature.get("width_m") or 45.0,
    }


def runway_area_polygon(feature):
    points = runway_centerline_points(feature)
    if points is None or len(points) < 2:
        return None

    lon1, lat1 = points[0]
    lon2, lat2 = points[-1]
    mean_lat = (lat1 + lat2) / 2.0
    meters_per_lat = 111320.0
    meters_per_lon = max(1.0, meters_per_lat * math.cos(math.radians(mean_lat)))
    dx = (lon2 - lon1) * meters_per_lon
    dy = (lat2 - lat1) * meters_per_lat
    length = math.hypot(dx, dy)
    if length <= 0:
        return None

    width_m = max(
        float(feature.get("width_m") or 45.0),
        TASK_MAP_RUNWAY_VISIBLE_WIDTH_M,
    )
    half_width = width_m / 2.0
    ux = -dy / length
    uy = dx / length
    dlon = ux * half_width / meters_per_lon
    dlat = uy * half_width / meters_per_lat

    polygon = [
        (lon1 + dlon, lat1 + dlat),
        (lon2 + dlon, lat2 + dlat),
        (lon2 - dlon, lat2 - dlat),
        (lon1 - dlon, lat1 - dlat),
        (lon1 + dlon, lat1 + dlat),
    ]
    return {"label": feature.get("label") or "", "points": polygon}


def runway_polygon_layers(features):
    polygons = []
    for feature in features or ():
        polygon = runway_area_polygon(feature)
        if polygon is not None:
            polygons.append(polygon)

    if not polygons:
        return {}

    return {"runway_area": polygons}


def runway_polyline_layers(features):
    centerlines = []
    for feature in features or ():
        centerline = runway_centerline_feature(feature)
        if centerline is not None:
            centerlines.append(centerline)

    if not centerlines:
        return {}
    return {
        "runway_casing_line": centerlines,
        "runway_line": centerlines,
    }


def dbf_field_specs(data: bytes):
    if len(data) < 32:
        return [], 0, 0, b""
    header_len = struct.unpack_from("<H", data, 8)[0]
    record_len = struct.unpack_from("<H", data, 10)[0]
    fields = []
    offset = 32
    while offset + 32 <= header_len and data[offset] != 0x0D:
        raw = data[offset:offset + 32]
        name = raw[:11].split(b"\0", 1)[0].decode("latin1", errors="replace").strip()
        length = raw[16]
        fields.append((name, length))
        offset += 32
    return fields, header_len, record_len, data[32:header_len]


def dbf_rows(data: bytes):
    fields, header_len, record_len, _ = dbf_field_specs(data)
    if not fields or record_len <= 0:
        return []
    count = struct.unpack_from("<I", data, 4)[0]
    rows = []
    for index in range(count):
        start = header_len + index * record_len
        row = data[start:start + record_len]
        if len(row) != record_len:
            break
        rows.append(row)
    return rows


def dbf_value(row: bytes, fields, key: str) -> str:
    position = 1
    for name, length in fields:
        value = row[position:position + length]
        if name.lower() == key.lower():
            return value.decode("latin1", errors="replace").strip()
        position += length
    return ""


def point_record_xy(content: bytes):
    if len(content) < 20:
        return None
    shape_type = struct.unpack_from("<i", content, 0)[0]
    if shape_type != 1:
        return None
    return struct.unpack_from("<dd", content, 4)


def shp_records(data: bytes):
    if len(data) < 100:
        return b"", []
    header = data[:100]
    offset = 100
    records = []
    while offset + 8 <= len(data):
        _, length_words = struct.unpack_from(">ii", data, offset)
        offset += 8
        content = data[offset:offset + length_words * 2]
        offset += length_words * 2
        bbox = crop.shp_record_bbox(content)
        records.append({"content": content, "length_words": length_words, "bbox": bbox})
    return header, records


def geodesic_distance_sq_m(a, b):
    lon1, lat1 = a
    lon2, lat2 = b
    mean_lat = math.radians((lat1 + lat2) / 2.0)
    meters_per_lat = 111320.0
    meters_per_lon = meters_per_lat * max(0.01, math.cos(mean_lat))
    dx = (lon1 - lon2) * meters_per_lon
    dy = (lat1 - lat2) * meters_per_lat
    return dx * dx + dy * dy


def parse_population(value: str) -> int:
    try:
        return int(float(str(value or "0").replace(",", ".")))
    except ValueError:
        return 0


def thin_label_point_layers(layer_payloads, min_distance_m: float):
    candidates = []
    for layer_name, payload in layer_payloads.items():
        fields, _, _, _ = dbf_field_specs(payload["dbf"])
        rows = dbf_rows(payload["dbf"])
        for index, record in enumerate(payload["records"]):
            if index >= len(rows):
                continue
            xy = point_record_xy(record["content"])
            if xy is None:
                continue
            row = rows[index]
            candidates.append(
                {
                    "layer": layer_name,
                    "index": index,
                    "xy": xy,
                    "name": dbf_value(row, fields, "name"),
                    "population": parse_population(dbf_value(row, fields, "population")),
                    "priority": TASK_MAP_LABEL_LAYER_PRIORITY.get(layer_name, 99),
                }
            )

    candidates.sort(
        key=lambda item: (
            item["priority"],
            -item["population"],
            item["name"],
            item["index"],
        )
    )

    keep = {layer_name: set() for layer_name in layer_payloads}
    accepted = []
    min_distance_sq = min_distance_m * min_distance_m
    for candidate in candidates:
        if any(geodesic_distance_sq_m(candidate["xy"], chosen["xy"]) < min_distance_sq
               for chosen in accepted):
            continue
        accepted.append(candidate)
        keep[candidate["layer"]].add(candidate["index"])

    return keep, len(candidates), len(candidates) - len(accepted)


def build_shp_bytes(header: bytes, records):
    length_words = (100 + sum(8 + len(record["content"]) for record in records)) // 2
    out = bytearray(crop.update_shp_header(header, length_words, records))
    for number, record in enumerate(records, 1):
        out.extend(struct.pack(">ii", number, record["length_words"]))
        out.extend(record["content"])
    return bytes(out)


def build_shx_bytes(header: bytes, records):
    length_words = (100 + len(records) * 8) // 2
    out = bytearray(crop.update_shp_header(header, length_words, records))
    offset_words = 50
    for record in records:
        out.extend(struct.pack(">ii", offset_words, record["length_words"]))
        offset_words += 4 + record["length_words"]
    return bytes(out)


def build_dbf_bytes(dbf: bytes, keep_indices):
    if len(dbf) < 32:
        return dbf
    fields, header_len, record_len, rest_header = dbf_field_specs(dbf)
    if not fields or record_len <= 0:
        return dbf
    rows = dbf_rows(dbf)
    selected = [row for index, row in enumerate(rows) if index in keep_indices]
    header = bytearray(dbf[:32])
    struct.pack_into("<I", header, 4, len(selected))
    return bytes(header) + rest_header + b"".join(selected) + b"\x1a"


def blank_dbf_name_fields(dbf: bytes):
    if len(dbf) < 32:
        return dbf, 0

    fields, header_len, record_len, _ = dbf_field_specs(dbf)
    if not fields or record_len <= 0:
        return dbf, 0

    targets = []
    position = 1
    for name, length in fields:
        if name.lower() == "name":
            targets.append((position, length))
        position += length

    if not targets:
        return dbf, 0

    out = bytearray(dbf)
    count = struct.unpack_from("<I", dbf, 4)[0]
    changed = 0
    for index in range(count):
        start = header_len + index * record_len
        end = start + record_len
        if end > len(out):
            break
        if out[start:start + 1] == b"*":
            continue

        changed_row = False
        for offset, length in targets:
            field_start = start + offset
            field_end = field_start + length
            if bytes(out[field_start:field_end]).strip():
                out[field_start:field_end] = b" " * length
                changed_row = True
        if changed_row:
            changed += 1

    return bytes(out), changed


def rewrite_xcm_with_thinned_labels(xcm_bytes: bytes):
    if TASK_MAP_LABEL_SPACING_M <= 0 and not TASK_MAP_SUPPRESSED_NAME_LAYERS:
        return xcm_bytes, {}

    with tempfile.TemporaryDirectory(prefix="kigo_label_thin_") as tmp:
        src_path = Path(tmp) / "src.xcm"
        dst_path = Path(tmp) / "dst.xcm"
        src_path.write_bytes(xcm_bytes)

        with zipfile.ZipFile(src_path) as zin:
            names = set(zin.namelist())
            layer_payloads = {}
            for layer_name in TASK_MAP_LABEL_POINT_LAYERS:
                required = {f"{layer_name}.shp", f"{layer_name}.shx", f"{layer_name}.dbf"}
                if not required.issubset(names):
                    continue
                header, records = shp_records(zin.read(f"{layer_name}.shp"))
                layer_payloads[layer_name] = {
                    "header": header,
                    "records": records,
                    "dbf": zin.read(f"{layer_name}.dbf"),
                    "shx": zin.read(f"{layer_name}.shx"),
                }

            replacements = {}
            changed_layers = set()
            stats = {}

            if layer_payloads and TASK_MAP_LABEL_SPACING_M > 0:
                keep, total, removed = thin_label_point_layers(
                    layer_payloads,
                    TASK_MAP_LABEL_SPACING_M,
                )
                stats.update({"total": total, "removed": removed, "layers": {}})
                for layer_name, payload in layer_payloads.items():
                    keep_indices = keep.get(layer_name, set())
                    records = [
                        record
                        for index, record in enumerate(payload["records"])
                        if index in keep_indices
                    ]
                    before = len(payload["records"])
                    after = len(records)
                    if before == after:
                        continue
                    changed_layers.add(layer_name)
                    stats["layers"][layer_name] = {"before": before, "after": after}
                    replacements[f"{layer_name}.shp"] = build_shp_bytes(payload["header"], records)
                    replacements[f"{layer_name}.shx"] = build_shx_bytes(payload["header"], records)
                    replacements[f"{layer_name}.dbf"] = build_dbf_bytes(payload["dbf"], keep_indices)

            suppressed = {}
            for layer_name in TASK_MAP_SUPPRESSED_NAME_LAYERS:
                dbf_name = f"{layer_name}.dbf"
                if dbf_name not in names:
                    continue
                dbf = replacements.get(dbf_name)
                if dbf is None:
                    dbf = zin.read(dbf_name)
                cleaned, changed = blank_dbf_name_fields(dbf)
                if changed <= 0:
                    continue
                replacements[dbf_name] = cleaned
                suppressed[layer_name] = changed

            if suppressed:
                stats["suppressed_names"] = suppressed

            if not replacements:
                return xcm_bytes, stats

            with zipfile.ZipFile(dst_path, "w", compression=zipfile.ZIP_STORED) as zout:
                for info in zin.infolist():
                    if info.filename in replacements:
                        new_info = zipfile.ZipInfo(info.filename, date_time=info.date_time)
                        new_info.external_attr = info.external_attr
                        new_info.compress_type = zipfile.ZIP_STORED
                        zout.writestr(new_info, replacements[info.filename])
                        continue
                    if any(info.filename == f"{layer}.qix" for layer in changed_layers):
                        continue
                    new_info = zipfile.ZipInfo(info.filename, date_time=info.date_time)
                    new_info.external_attr = info.external_attr
                    new_info.compress_type = zipfile.ZIP_STORED
                    with zin.open(info) as src, zout.open(new_info, "w") as dst:
                        shutil.copyfileobj(src, dst, length=1024 * 1024)

        return dst_path.read_bytes(), stats


def validate_bbox(bbox):
    if bbox["south"] >= bbox["north"]:
        raise ValueError("bbox.south must be less than bbox.north")
    if bbox["west"] >= bbox["east"]:
        raise ValueError("bbox.west must be less than bbox.east")
    if bbox["south"] < -90 or bbox["north"] > 90:
        raise ValueError("bbox latitude values must be within -90..90")


def bbox_contains(outer, inner) -> bool:
    epsilon = 1e-9
    return (
        outer["south"] <= inner["south"] + epsilon
        and outer["west"] <= inner["west"] + epsilon
        and outer["north"] >= inner["north"] - epsilon
        and outer["east"] >= inner["east"] - epsilon
    )


def bbox_intersects(a, b) -> bool:
    return not (
        a["east"] < b["west"]
        or a["west"] > b["east"]
        or a["north"] < b["south"]
        or a["south"] > b["north"]
    )


def bbox_union(boxes):
    boxes = list(boxes)
    if not boxes:
        return None
    return {
        "south": min(box["south"] for box in boxes),
        "west": min(box["west"] for box in boxes),
        "north": max(box["north"] for box in boxes),
        "east": max(box["east"] for box in boxes),
    }


def bbox_area_key(bbox):
    return max(0.0, bbox["north"] - bbox["south"]) * max(0.0, bbox["east"] - bbox["west"])


def bbox_header_text(bbox) -> str:
    return (
        f"{bbox['south']:.8f},{bbox['west']:.8f},"
        f"{bbox['north']:.8f},{bbox['east']:.8f}"
    )


def select_base_map(base_maps: tuple[BaseMap, ...], bbox) -> BaseMap:
    for base_map in base_maps:
        if not bbox_contains(base_map.bbox, bbox):
            continue
        if base_map.topology_bbox is None or not bbox_contains(base_map.topology_bbox, bbox):
            print(
                f"[base-map] {base_map.path.name}: terrain OK but topology "
                f"S={base_map.topology_bbox['south'] if base_map.topology_bbox else 'n/a':.4f} "
                f"does not cover task S={bbox['south']:.4f} — skipping",
                file=sys.stderr, flush=True,
            )
            continue
        return base_map

    formatted = (
        f"{bbox['south']:.6f},{bbox['west']:.6f},"
        f"{bbox['north']:.6f},{bbox['east']:.6f}"
    )
    raise ValueError(f"no base map covers requested bbox {formatted}")


def load_source_tiles() -> tuple[SourceTile, ...]:
    manifest_path = TASK_MAP_SOURCE_REPO / "manifest"
    if not manifest_path.exists():
        return ()
    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    datasets = manifest.get("topology", {}).get("datasets", {}).get("osm", [])
    tiles = []
    for dataset in datasets:
        name = str(dataset.get("name") or "")
        bounds = dataset.get("bounds")
        if not name or not isinstance(bounds, list) or len(bounds) != 4:
            continue
        left, right, top, bottom = (float(value) for value in bounds)
        tiles.append(
            SourceTile(
                name=name,
                bbox={"south": bottom, "west": left, "north": top, "east": right},
            )
        )
    return tuple(tiles)


def source_repo_fingerprint() -> str:
    digest = hashlib.sha1()
    digest.update(TASK_MAP_XCM_CACHE_VERSION.encode("ascii"))
    for name in ("manifest", "checksums"):
        path = TASK_MAP_SOURCE_REPO / name
        if not path.exists():
            digest.update(f"{name}:missing".encode("ascii"))
            continue
        digest.update(name.encode("ascii"))
        digest.update(path.read_bytes())
    return digest.hexdigest()


def select_source_tile_cache(required_bbox):
    tiles = load_source_tiles()
    if not tiles:
        return None

    selected = [tile for tile in tiles if bbox_intersects(tile.bbox, required_bbox)]
    if not selected:
        return None

    union = bbox_union(tile.bbox for tile in selected)
    if union is None or not bbox_contains(union, required_bbox):
        return None
    if len(selected) > TASK_MAP_TILE_CACHE_MAX_TILES:
        return None
    return tuple(sorted(selected, key=lambda tile: tile.name)), union


def xcm_cache_digest(kind: str, source_key: str, bbox, tile_names=()) -> str:
    payload = {
        "version": TASK_MAP_XCM_CACHE_VERSION,
        "kind": kind,
        "source_key": source_key,
        "bbox": {key: round(float(value), 8) for key, value in sorted(bbox.items())},
        "tiles": list(tile_names),
        "runway_width_m": TASK_MAP_RUNWAY_VISIBLE_WIDTH_M,
    }
    text = json.dumps(payload, sort_keys=True, separators=(",", ":"))
    return hashlib.sha1(text.encode("utf-8")).hexdigest()


def xcm_cache_paths(cache_key: str):
    return (
        TASK_MAP_XCM_CACHE_DIR / f"{cache_key}.xcm",
        TASK_MAP_XCM_CACHE_DIR / f"{cache_key}.json",
    )


def read_cached_xcm(cache_key: str):
    xcm_path, meta_path = xcm_cache_paths(cache_key)
    if not xcm_path.exists() or not meta_path.exists():
        return None
    try:
        metadata = json.loads(meta_path.read_text(encoding="utf-8"))
        return xcm_path.read_bytes(), metadata, xcm_path
    except Exception:
        return None


def find_covering_cached_xcm(required_bbox, source_key: str):
    if not TASK_MAP_XCM_CACHE_DIR.exists():
        return None

    candidates = []
    for meta_path in TASK_MAP_XCM_CACHE_DIR.glob("*.json"):
        try:
            metadata = json.loads(meta_path.read_text(encoding="utf-8"))
            if metadata.get("source_key") != source_key:
                continue
            cached_bbox = metadata.get("bbox")
            if not isinstance(cached_bbox, dict) or not bbox_contains(cached_bbox, required_bbox):
                continue
            xcm_path = TASK_MAP_XCM_CACHE_DIR / f"{meta_path.stem}.xcm"
            if not xcm_path.exists():
                continue
            candidates.append((bbox_area_key(cached_bbox), xcm_path, metadata))
        except Exception:
            continue

    if not candidates:
        return None

    _, xcm_path, metadata = min(candidates, key=lambda item: item[0])
    try:
        return xcm_path.read_bytes(), metadata, xcm_path
    except Exception:
        return None


def save_cached_xcm(cache_key: str, data: bytes, metadata: dict) -> None:
    TASK_MAP_XCM_CACHE_DIR.mkdir(parents=True, exist_ok=True)
    xcm_path, meta_path = xcm_cache_paths(cache_key)
    tmp_xcm = xcm_path.with_suffix(".xcm.tmp")
    tmp_meta = meta_path.with_suffix(".json.tmp")
    tmp_xcm.write_bytes(data)
    tmp_meta.write_text(
        json.dumps(metadata, ensure_ascii=False, sort_keys=True, indent=2) + "\n",
        encoding="utf-8",
    )
    os.replace(tmp_xcm, xcm_path)
    os.replace(tmp_meta, meta_path)


def build_cache_metadata(kind: str, source_key: str, bbox, request_bbox,
                         required_bbox, tile_names, bytes_count: int,
                         runway_count: int, runway_source: str):
    return {
        "version": TASK_MAP_XCM_CACHE_VERSION,
        "kind": kind,
        "source_key": source_key,
        "bbox": bbox,
        "request_bbox": request_bbox,
        "required_bbox": required_bbox,
        "tiles": list(tile_names),
        "bytes": bytes_count,
        "runways": runway_count,
        "runway_source": runway_source,
        "created_epoch": time.time(),
    }


# ---------------------------------------------------------------------------
# Mapgen fallback — generates a new XCM from scratch when no base map covers
# the requested bbox.  Uses the XCSoar Map Generator running on the same host.
# ---------------------------------------------------------------------------

MAPGEN_URL = os.environ.get(
    "KIGO_MAPGEN_URL", "http://172.17.0.1:9091"
)
MAPGEN_TIMEOUT_S = int(os.environ.get("KIGO_MAPGEN_TIMEOUT_S", "540"))
MAPGEN_POLL_S = float(os.environ.get("KIGO_MAPGEN_POLL_S", "10"))


class _StopRedirect(urllib.request.HTTPRedirectHandler):
    """Raise HTTPError on any redirect so we can capture the Location header."""

    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None


def _mapgen_submit(bbox, name):
    """POST to mapgen and return job UUID.  Raises on failure."""
    form = {
        "name": (name or "task_map")[:80],
        "mail": "",
        "high_quality": "on",      # 1 arc-second, level-of-detail 4
        "welt2000": "on",          # airport / airstrip waypoints
        "omit_path_track_lines": "on",  # exclude clutter paths & tracks
        "selection": "bounds",
        "left":   f"{bbox['west']:.6f}",
        "right":  f"{bbox['east']:.6f}",
        "top":    f"{bbox['north']:.6f}",
        "bottom": f"{bbox['south']:.6f}",
    }
    body = urllib.parse.urlencode(form).encode("utf-8")
    req = urllib.request.Request(
        MAPGEN_URL + "/",
        data=body,
        headers={"Content-Type": "application/x-www-form-urlencoded"},
    )
    opener = urllib.request.build_opener(_StopRedirect())
    try:
        opener.open(req, timeout=30)
        raise RuntimeError("mapgen did not redirect after job submission")
    except urllib.error.HTTPError as exc:
        if exc.code not in (301, 302, 303, 307, 308):
            raise
        location = exc.headers.get("Location", "")
    # Location is e.g. "/status?uuid=abc123"
    if "uuid=" not in location:
        raise RuntimeError(f"unexpected mapgen redirect: {location!r}")
    return location.split("uuid=", 1)[1].strip()


def _mapgen_poll(uuid, timeout_s):
    """Poll mapgen /status until 'done', 'error', or timeout."""
    deadline = time.monotonic() + timeout_s
    url = f"{MAPGEN_URL}/status?uuid={uuid}"
    while time.monotonic() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=20) as resp:
                html = resp.read().decode("utf-8", errors="replace")
            if "is ready to download" in html:
                return "done"
            if "Generation failed" in html or "<title>Error" in html:
                return "error"
        except Exception:
            pass
        time.sleep(MAPGEN_POLL_S)
    return "timeout"


def _xcm_has_terrain(xcm_bytes):
    """Return True if the XCM (bytes) contains a terrain.jp2 file."""
    try:
        import io
        with zipfile.ZipFile(io.BytesIO(xcm_bytes)) as zf:
            return "terrain.jp2" in zf.namelist()
    except Exception:
        return False


def generate_map_from_mapgen(bbox, name, runway_features=None):
    """Generate a new XCM map via mapgen, inject runways, return bytes or None."""
    try:
        uuid = _mapgen_submit(bbox, name)
    except Exception as exc:
        print(f"[mapgen] submit failed: {exc}", file=sys.stderr, flush=True)
        return None, f"mapgen submit error: {exc}"

    print(
        f"[mapgen] submitted name={name!r} uuid={uuid} bbox={bbox['south']:.4f},"
        f"{bbox['west']:.4f},{bbox['north']:.4f},{bbox['east']:.4f}",
        file=sys.stderr, flush=True,
    )

    status = _mapgen_poll(uuid, MAPGEN_TIMEOUT_S)
    if status != "done":
        print(f"[mapgen] job {uuid} ended: {status}", file=sys.stderr, flush=True)
        return None, f"mapgen {status}"

    # Download the generated XCM
    try:
        with urllib.request.urlopen(
            f"{MAPGEN_URL}/download?uuid={uuid}", timeout=120
        ) as resp:
            raw = resp.read()
    except Exception as exc:
        print(f"[mapgen] download failed {uuid}: {exc}", file=sys.stderr, flush=True)
        return None, f"mapgen download error: {exc}"

    # Inject runway polygons into topology if available.
    if runway_features and _xcm_has_terrain(raw):
        try:
            with tempfile.TemporaryDirectory(prefix="kigo_mapgen_rw_") as tmp:
                src = Path(tmp) / "base.xcm"
                dst = Path(tmp) / "out.xcm"
                src.write_bytes(raw)
                crop.crop_xcm_to_bbox(
                    src, bbox, dst,
                    excluded_vector_stems=TASK_MAP_EXCLUDED_VECTOR_STEMS,
                    forced_topology_rows=TASK_MAP_FORCED_TOPOLOGY_ROWS,
                    extra_polyline_layers=runway_polyline_layers(runway_features),
                    extra_polygon_layers=runway_polygon_layers(runway_features),
                    skip_terrain_crop=True,
                )
                raw = dst.read_bytes()
        except Exception as exc:
            print(
                f"[mapgen] runway injection failed (returning plain map): {exc}",
                file=sys.stderr, flush=True,
            )

    try:
        raw, label_stats = rewrite_xcm_with_thinned_labels(raw)
        if label_stats:
            print(
                f"[mapgen] label thinning stats={json.dumps(label_stats, sort_keys=True)}",
                file=sys.stderr,
                flush=True,
            )
    except Exception as exc:
        print(
            f"[mapgen] label thinning failed (returning unthinned map): {exc}",
            file=sys.stderr,
            flush=True,
        )

    print(f"[mapgen] done name={name!r} uuid={uuid} bytes={len(raw)}", file=sys.stderr, flush=True)
    return raw, ""


class TaskMapHandler(BaseHTTPRequestHandler):
    server_version = "KigoTaskMapHTTP/1.0"
    base_maps: tuple[BaseMap, ...]

    def send_text(self, status: int, message: str):
        body = (message.rstrip() + "\n").encode("utf-8", errors="replace")
        self.send_response(status)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_xcm(self, data: bytes, *, bbox, task_name: str, map_name: str,
                 task_points, runway_features, runway_source: str,
                 runway_error: str, map_source: str, cache_status: str,
                 cache_key: str = "", tile_names=()):
        self.send_response(200)
        self.send_header("Content-Type", "application/octet-stream")
        self.send_header("Content-Disposition", "attachment; filename=task_map_30km.xcm")
        self.send_header("Content-Length", str(len(data)))
        self.send_header("X-Kigo-Bbox", bbox_header_text(bbox))
        self.send_header("X-Kigo-Base-Map", map_source)
        self.send_header("X-Kigo-Map-Source", map_source)
        self.send_header("X-Kigo-Map-Name", map_name)
        self.send_header("X-Kigo-Task-Points", str(len(task_points)))
        self.send_header("X-Kigo-Runways", str(len(runway_features or ())))
        self.send_header("X-Kigo-Runway-Source", runway_source)
        self.send_header("X-Kigo-Cache", cache_status)
        if cache_key:
            self.send_header("X-Kigo-Cache-Key", cache_key[:40])
        if tile_names:
            self.send_header("X-Kigo-Source-Tiles", ",".join(tile_names))
        if runway_error:
            self.send_header("X-Kigo-Runway-Error", runway_error[:200])
        self.end_headers()
        self.wfile.write(data)
        self.log_message(
            "task-map generated task=%r map_name=%r source=%s cache=%s points=%d runways=%d runway_source=%s runway_error=%r bbox=%s bytes=%d tiles=%s",
            task_name,
            map_name,
            map_source,
            cache_status,
            len(task_points),
            len(runway_features or ()),
            runway_source,
            runway_error,
            bbox_header_text(bbox),
            len(data),
            ",".join(tile_names),
        )

    def do_GET(self):
        if self.path == "/health":
            self.send_text(200, "ok")
        else:
            self.send_text(404, "not found")

    def do_POST(self):
        if self.path != "/api/task-map":
            self.send_text(404, "not found")
            return

        try:
            length = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            self.send_text(400, "invalid Content-Length")
            return

        if length <= 0 or length > 1024 * 1024:
            self.send_text(413, "invalid request size")
            return

        try:
            payload = json.loads(self.rfile.read(length).decode("utf-8"))
            if not isinstance(payload, dict):
                raise ValueError("payload must be a JSON object")
            bbox = bbox_from_payload(payload)
            validate_bbox(bbox)
            task_points = task_points_from_payload(payload)
            required_bbox = route_cache_bbox(payload, bbox, task_points)
            validate_bbox(required_bbox)
        except Exception as exc:
            self.send_text(400, f"bad task map request: {exc}")
            return

        bbox_header = bbox_header_text(bbox)
        task_name = str(payload.get("task_name") or "task_map")
        map_name = f"{task_name}_gen"
        self.log_message(
            "task-map request task=%r map_name=%r bbox=%s required_bbox=%s points=%s",
            task_name,
            map_name,
            bbox_header,
            bbox_header_text(required_bbox),
            payload_points_summary(payload),
        )

        source_key = source_repo_fingerprint()
        cached = find_covering_cached_xcm(required_bbox, source_key)
        if cached is not None:
            data, metadata, _ = cached
            cached_bbox = metadata.get("bbox") if isinstance(metadata.get("bbox"), dict) else bbox
            self.send_xcm(
                data,
                bbox=cached_bbox,
                task_name=task_name,
                map_name=map_name,
                task_points=task_points,
                runway_features=[None] * int(metadata.get("runways") or 0),
                runway_source=str(metadata.get("runway_source") or "cache"),
                runway_error="",
                map_source="xcm-cache",
                cache_status="hit",
                cache_key=str(metadata.get("cache_key") or ""),
                tile_names=metadata.get("tiles") or (),
            )
            return

        tile_cache = select_source_tile_cache(required_bbox)
        if tile_cache is not None:
            tiles, cache_bbox = tile_cache
            tile_names = tuple(tile.name for tile in tiles)
            cache_key = xcm_cache_digest("source-tiles", source_key, cache_bbox, tile_names)
            cached = read_cached_xcm(cache_key)
            if cached is not None:
                data, metadata, _ = cached
                self.send_xcm(
                    data,
                    bbox=cache_bbox,
                    task_name=task_name,
                    map_name=map_name,
                    task_points=task_points,
                    runway_features=[None] * int(metadata.get("runways") or 0),
                    runway_source=str(metadata.get("runway_source") or "cache"),
                    runway_error="",
                    map_source="xcm-cache",
                    cache_status="hit",
                    cache_key=cache_key,
                    tile_names=tile_names,
                )
                return

            try:
                runway_features, runway_error, runway_source = fetch_osm_runways(cache_bbox)
            except Exception as exc:
                runway_features = []
                runway_error = str(exc)
                runway_source = "none"

            data, mapgen_error = generate_map_from_mapgen(
                cache_bbox,
                "tiles_" + "_".join(name.rsplit("/", 1)[-1] for name in tile_names),
                runway_features=runway_features,
            )
            if data is None:
                self.log_message(
                    "tile-cache generation failed task=%r tiles=%s error=%r; falling back to exact bbox",
                    task_name,
                    ",".join(tile_names),
                    mapgen_error,
                )
            else:
                metadata = build_cache_metadata(
                    "source-tiles",
                    source_key,
                    cache_bbox,
                    bbox,
                    required_bbox,
                    tile_names,
                    len(data),
                    len(runway_features),
                    runway_source,
                )
                metadata["cache_key"] = cache_key
                save_cached_xcm(cache_key, data, metadata)
                self.send_xcm(
                    data,
                    bbox=cache_bbox,
                    task_name=task_name,
                    map_name=map_name,
                    task_points=task_points,
                    runway_features=runway_features,
                    runway_source=runway_source,
                    runway_error=runway_error,
                    map_source="mapgen-source-tiles",
                    cache_status="miss-filled",
                    cache_key=cache_key,
                    tile_names=tile_names,
                )
                return

        exact_key = xcm_cache_digest("exact-bbox", source_key, bbox)
        cached = read_cached_xcm(exact_key)
        if cached is not None:
            data, metadata, _ = cached
            self.send_xcm(
                data,
                bbox=bbox,
                task_name=task_name,
                map_name=map_name,
                task_points=task_points,
                runway_features=[None] * int(metadata.get("runways") or 0),
                runway_source=str(metadata.get("runway_source") or "cache"),
                runway_error="",
                map_source="xcm-cache",
                cache_status="exact-hit",
                cache_key=exact_key,
            )
            return

        try:
            runway_features, runway_error, runway_source = fetch_osm_runways(bbox)
        except Exception as exc:
            runway_features = []
            runway_error = str(exc)
            runway_source = "none"

        data, mapgen_error = generate_map_from_mapgen(
            bbox,
            map_name,
            runway_features=runway_features,
        )
        if data is None:
            self.send_text(500, f"task map failed: {mapgen_error}")
            return

        metadata = build_cache_metadata(
            "exact-bbox",
            source_key,
            bbox,
            bbox,
            required_bbox,
            (),
            len(data),
            len(runway_features),
            runway_source,
        )
        metadata["cache_key"] = exact_key
        save_cached_xcm(exact_key, data, metadata)
        self.send_xcm(
            data,
            bbox=bbox,
            task_name=task_name,
            map_name=map_name,
            task_points=task_points,
            runway_features=runway_features,
            runway_source=runway_source,
            runway_error=runway_error,
            map_source="mapgen",
            cache_status="exact-miss-filled",
            cache_key=exact_key,
        )


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--host", default=os.environ.get("KIGO_TASK_MAP_HOST", "0.0.0.0"))
    parser.add_argument(
        "--port",
        type=int,
        default=int(os.environ.get("KIGO_TASK_MAP_PORT", "8787")),
    )
    parser.add_argument("--base-xcm", type=Path)
    args = parser.parse_args()

    TaskMapHandler.base_maps = find_base_maps(args.base_xcm)
    server = ThreadingHTTPServer((args.host, args.port), TaskMapHandler)
    print(
        f"Kigo task map service listening on {args.host}:{args.port}; "
        "bases=" + ", ".join(str(base.path) for base in TaskMapHandler.base_maps),
        flush=True,
    )
    server.serve_forever()


if __name__ == "__main__":
    main()
