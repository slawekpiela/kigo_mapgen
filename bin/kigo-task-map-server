    "/maps/POL_HighRes_1arcsec.xcm",
    "/maps/POL_HighRes_base.xcm",
    "/maps/nowa_mapa2.xcm",
    "/maps/nowa_mapa.xcm",
    "/home/slawek/mapgen-output/slawek4.xcm",
    "/home/slawek/mapgen-output/slawek5.xcm",
    "/home/slawek/mapgen-output/POL_HighRes_1arcsec.xcm",
    "/home/slawek/mapgen-output/POL_HighRes_base.xcm",
    "/home/slawek/mapgen-output/nowa_mapa2.xcm",
    "/home/slawek/mapgen-output/nowa_mapa.xcm",
)

TASK_MAP_EXCLUDED_VECTOR_STEMS = frozenset(("path_line", "track_line"))
TASK_MAP_FORCED_TOPOLOGY_ROWS = {
    "airstrip_area": "airstrip_area,10,,1,187,187,204,1,1,1,255",
    "runway_area": "runway_area,20,,0,25,25,25,1,0,0,255",
    "runway_casing_line": "runway_casing_line,20,,0,0,0,0,15,0,0,255",
    "runway_line": "runway_line,20,,0,255,255,255,7,0,0,255",
}
TASK_MAP_MARGIN_KM = 30.0
