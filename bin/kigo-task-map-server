            "https://overpass.kumi.systems/api/interpreter",
        ),
    ).replace(";", ",").split(",")
    if url.strip()
)
TASK_MAP_OVERPASS_TIMEOUT_S = float(os.environ.get("KIGO_TASK_MAP_OVERPASS_TIMEOUT_S", "25"))
TASK_MAP_OVERPASS_ATTEMPTS = int(os.environ.get("KIGO_TASK_MAP_OVERPASS_ATTEMPTS", "2"))
TASK_MAP_RUNWAY_CACHE_DIR = Path(
    os.environ.get("KIGO_TASK_MAP_RUNWAY_CACHE_DIR", "/tmp/kigo_task_map_runways")
