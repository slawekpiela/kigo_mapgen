#!/usr/bin/env python3
"""HTTP task-map service for Kigo remote map generation.

Kigo posts the active task's extreme points plus its requested bbox.  The
service first tries a ready XCM cache whose map still leaves the route at least
20 km from the edge, then builds and caches a high-quality tile-union XCM when
the task fits in a small source-tile set, and finally falls back to an exact
bbox mapgen request.
"""

from __future__ import annotations

import argparse
from dataclasses import dataclass
import hashlib
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer
import json
import math
import os
from pathlib import Path
import shutil
import struct
import sys
import tempfile
import time
import urllib.error
import urllib.parse
import urllib.request
import zipfile

SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

import crop_xcm_corridor as crop


