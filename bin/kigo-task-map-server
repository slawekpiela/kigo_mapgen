@dataclass(frozen=True)
class BaseMap:
    path: Path
    bbox: dict[str, float]           # terrain coverage
    topology_bbox: "dict | None"     # topology coverage, None = no shapefile data


@dataclass(frozen=True)
class SourceTile:
    name: str
    bbox: dict[str, float]


def xcm_terrain_bbox(xcm: Path):
    with zipfile.ZipFile(xcm) as zf, tempfile.TemporaryDirectory(
        prefix="kigo_task_map_base_"
    ) as tmp:
        zf.extract("terrain.j2w", tmp)
        zf.extract("terrain.jp2", tmp)
        world_path = Path(tmp) / "terrain.j2w"
        terrain_path = Path(tmp) / "terrain.jp2"

        a, d, b, e, c, f = crop.read_world(world_path)
        if abs(b) > 1e-12 or abs(d) > 1e-12 or a <= 0 or e >= 0:
            raise ValueError("only north-up terrain.j2w files are supported")

        width, height = crop.image_size(terrain_path)

    west = c - a / 2.0
    east = west + a * width
    north = f - e / 2.0
    south = north + e * height
    return {"south": south, "west": west, "north": north, "east": east}


def base_map_tile_dirs() -> tuple[Path, ...]:
    configured = os.environ.get("KIGO_TASK_MAP_BASE_TILE_DIRS")
    if configured:
        parts = configured.replace(";", ",").split(",")
        return tuple(Path(part.strip()) for part in parts if part.strip())
    return tuple(Path(path) for path in DEFAULT_BASE_MAP_TILE_DIRS)


def iter_base_map_candidates(configured):
    if configured is not None:
        yield configured

    env_path = os.environ.get("KIGO_TASK_MAP_BASE_XCM")
    if env_path:
        yield Path(env_path)

    for directory in base_map_tile_dirs():
        if not directory.exists() or not directory.is_dir():
            continue
        for candidate in sorted(directory.glob("*.xcm")):
            yield candidate

    for path in BASE_MAP_CANDIDATES:
        yield Path(path)


def find_base_maps(configured) -> tuple[BaseMap, ...]:
    seen = set()
    base_maps = []
    for candidate in iter_base_map_candidates(configured):
        if candidate in seen:
            continue
        seen.add(candidate)
        if candidate.exists():
            terrain_bbox = xcm_terrain_bbox(candidate)
            topology_bbox = crop.xcm_topology_bbox(candidate)
            base_maps.append(BaseMap(candidate, terrain_bbox, topology_bbox))

    if base_maps:
        return tuple(base_maps)

    raise FileNotFoundError(
        "No base XCM map found. Set --base-xcm or KIGO_TASK_MAP_BASE_XCM."
    )


def number(value, name: str) -> float:
    if isinstance(value, bool) or not isinstance(value, (int, float)):
        raise ValueError(f"{name} must be a number")
    return float(value)


def task_map_margin_km(payload) -> float:
    margin = number(payload.get("margin_km", TASK_MAP_MARGIN_KM), "margin_km")
    if margin <= 0:
        raise ValueError("margin_km must be positive")

    return max(TASK_MAP_MARGIN_KM, margin)


def bbox_from_dict(bbox_dict):
    if not isinstance(bbox_dict, dict):
        raise ValueError("bbox must be an object")

    return {
        "south": number(bbox_dict.get("south"), "bbox.south"),
        "west": number(bbox_dict.get("west"), "bbox.west"),
        "north": number(bbox_dict.get("north"), "bbox.north"),
        "east": number(bbox_dict.get("east"), "bbox.east"),
    }


def task_points_from_payload(payload):
    points = payload.get("points")
    if not isinstance(points, list):
        return []

    crop_points = []
    for index, point in enumerate(points):
        if not isinstance(point, dict):
            raise ValueError(f"points[{index}] must be an object")
        name = str(point.get("name") or point.get("role") or f"TP{index + 1:03d}")
        lat = number(point.get("lat"), f"points[{index}].lat")
        lon = number(point.get("lon"), f"points[{index}].lon")
        crop_points.append((name, lat, lon))

    return crop_points


def bbox_and_segments_from_payload(payload):
    """Return (bbox, corridor_segments) from payload.

    When a bbox is supplied, it is authoritative.  The posted points are kept
    for audit/logging and for older clients that only send point lists.
    """
    bbox_dict = payload.get("bbox")
    if isinstance(bbox_dict, dict):
        return bbox_from_dict(bbox_dict), []

    crop_points = task_points_from_payload(payload)
    if len(crop_points) >= 2:
        bbox = crop.buffered_bbox(crop_points, task_map_margin_km(payload))
        return bbox, crop.route_segments(crop_points)

    raise ValueError("payload must contain at least two points or bbox")


def bbox_from_payload(payload):
    bbox, _ = bbox_and_segments_from_payload(payload)
    return bbox


def route_cache_bbox(payload, request_bbox, task_points):
    if len(task_points) >= 2:
        return crop.buffered_bbox(task_points, TASK_MAP_ROUTE_TILE_MARGIN_KM)
    return request_bbox


def payload_point_count(payload) -> int:
    points = payload.get("points")
    return len(points) if isinstance(points, list) else 0


def payload_points_summary(payload) -> str:
    points = payload.get("points")
    if not isinstance(points, list):
        return ""

    parts = []
    for index, point in enumerate(points):
        if not isinstance(point, dict):
            parts.append(f"{index}:<invalid>")
            continue
        role = str(point.get("role") or index)
        name = str(point.get("name") or "")
        lat = point.get("lat")
        lon = point.get("lon")
        try:
            parts.append(f"{role}:{name}@{float(lat):.8f},{float(lon):.8f}")
        except (TypeError, ValueError):
            parts.append(f"{role}:{name}@<invalid>")

    return "; ".join(parts)


def runway_label(tags) -> str:
    if not isinstance(tags, dict):
        return ""
    return str(tags.get("ref") or tags.get("name") or "")


def runway_width_m(tags) -> float:
    if isinstance(tags, dict):
        raw_width = tags.get("width") or tags.get("est_width")
        if raw_width is not None:
            text = str(raw_width).strip().lower().replace(",", ".")
            if text.endswith("m"):
                text = text[:-1].strip()
            try:
                width = float(text)
                if 1 <= width <= 200:
                    return width
            except ValueError:
                pass

    return 45.0


def numeric_meters(value):
    if value is None:
        return None

    unit = None
    if isinstance(value, dict):
        unit = value.get("unit") or value.get("uom")
        for key in ("value", "val", "meters", "metres", "m"):
            if key in value:
                value = value.get(key)
                break
        else:
            return None

    if isinstance(value, (int, float)):
        number = float(value)
        text = ""
    else:
        text = str(value).strip().lower().replace(",", ".")
        match = re.search(r"-?\d+(?:\.\d+)?", text)
        if not match:
            return None
        number = float(match.group(0))

    unit_text = str(unit or "").strip().lower()
    if "ft" in unit_text or "feet" in unit_text or "foot" in unit_text:
        number *= 0.3048
    elif not unit_text and isinstance(value, str):
        if "ft" in text or "feet" in text or "foot" in text:
            number *= 0.3048

    if not math.isfinite(number) or number <= 0:
        return None
    return number


def nested_value(root, paths):
    for path in paths:
        value = root
        for key in path:
            if not isinstance(value, dict) or key not in value:
                value = None
                break
            value = value.get(key)
        if value is not None:
            return value
    return None


def openaip_runway_dimensions(runway):
    length = numeric_meters(
        nested_value(
            runway,
            (
                ("dimensions", "length"),
                ("dimension", "length"),
                ("length",),
                ("length_m",),
                ("lengthMeters",),
                ("lengthMetres",),
                ("runwayLength",),
                ("runway_length",),
            ),
        )
    )
    width = numeric_meters(
        nested_value(
            runway,
            (
                ("dimensions", "width"),
                ("dimension", "width"),
                ("width",),
                ("width_m",),
                ("widthMeters",),
                ("widthMetres",),
                ("runwayWidth",),
                ("runway_width",),
            ),
        )
    )

    if length is not None and not 20 <= length <= 8000:
        length = None
    if width is not None and not 1 <= width <= 300:
        width = None
    return length, width


def ordered_runway_designator_tokens(value):
    text = str(value or "").upper().replace("\\", "/").replace("-", "/")
    text = text.replace("RWY", " ")
    tokens = []
    seen = set()
    for number, suffix in re.findall(r"\b([0-3]?\d)([LCR]?)\b", text):
        runway_number = int(number)
        if runway_number == 0 or runway_number > 36:
            continue
        token = f"{runway_number:02d}{suffix}"
        if token not in seen:
            tokens.append(token)
            seen.add(token)
    return tuple(tokens)


def runway_designator_tokens(value):
    return set(ordered_runway_designator_tokens(value))


def runway_designator_heading_360(token):
    match = re.match(r"(\d{2})", str(token or "").upper())
    if not match:
        return None
    return (int(match.group(1)) * 10.0) % 360.0


def opposite_runway_designator(token):
    text = str(token or "").upper()
    match = re.match(r"(\d{2})([LCR]?)", text)
    if not match:
        return None
    runway_number = int(match.group(1))
    if runway_number == 0 or runway_number > 36:
        return None
    opposite_number = ((runway_number + 18 - 1) % 36) + 1
    suffix = {"L": "R", "R": "L"}.get(match.group(2), match.group(2))
    return f"{opposite_number:02d}{suffix}"


def runway_heading_from_designator(value):
    tokens = ordered_runway_designator_tokens(value)
    if not tokens:
        return None
    heading = runway_designator_heading_360(tokens[0])
    return None if heading is None else heading % 180.0


def normalise_heading_180(value):
    if isinstance(value, dict):
        for key in ("value", "val", "degrees", "degree"):
            if key in value:
                value = value.get(key)
                break
        else:
            return None

    if value is None:
        return None

    if isinstance(value, (int, float)):
        heading = float(value)
    else:
        text = str(value).strip().lower().replace(",", ".")
        match = re.search(r"-?\d+(?:\.\d+)?", text)
        if not match:
            return None
        heading = float(match.group(0))

    if not math.isfinite(heading):
        return None
    return heading % 180.0


def angle_diff_180(a, b):
    diff = abs((float(a) % 180.0) - (float(b) % 180.0))
    return min(diff, 180.0 - diff)


def angle_diff_360(a, b):
    diff = abs((float(a) % 360.0) - (float(b) % 360.0))
    return min(diff, 360.0 - diff)


def openaip_runway_label(runway):
    for key in ("designator", "name", "ident", "identifier", "ref"):
        value = runway.get(key) if isinstance(runway, dict) else None
        if value:
            return str(value)
    return ""


def openaip_runway_heading(runway, label):
    value = nested_value(
        runway,
        (
            ("trueHeading",),
            ("true_heading",),
            ("heading",),
            ("magneticHeading",),
            ("magnetic_heading",),
            ("direction",),
        ),
    )
    heading = normalise_heading_180(value)
    if heading is not None:
        return heading
    return runway_heading_from_designator(label)


def openaip_record_coordinates(record):
    geometry = record.get("_geometry") or record.get("geometry") or record.get("location")
    if isinstance(geometry, dict):
        coordinates = geometry.get("coordinates")
        if isinstance(coordinates, (list, tuple)) and len(coordinates) >= 2:
            try:
                return float(coordinates[0]), float(coordinates[1])
            except (TypeError, ValueError):
                pass
        lon = geometry.get("lon") or geometry.get("lng") or geometry.get("longitude")
        lat = geometry.get("lat") or geometry.get("latitude")
        if lon is not None and lat is not None:
            try:
                return float(lon), float(lat)
            except (TypeError, ValueError):
                pass

    coordinates = record.get("coordinates")
    if isinstance(coordinates, (list, tuple)) and len(coordinates) >= 2:
        try:
            return float(coordinates[0]), float(coordinates[1])
        except (TypeError, ValueError):
            pass
    if isinstance(coordinates, dict):
        lon = coordinates.get("lon") or coordinates.get("lng") or coordinates.get("longitude")
        lat = coordinates.get("lat") or coordinates.get("latitude")
        if lon is not None and lat is not None:
            try:
                return float(lon), float(lat)
            except (TypeError, ValueError):
                pass

    lon = (
        record.get("lon")
        or record.get("lng")
        or record.get("longitude")
        or record.get("long")
    )
    lat = record.get("lat") or record.get("latitude")
    if lon is None or lat is None:
        return None

    try:
        return float(lon), float(lat)
    except (TypeError, ValueError):
        return None


def iter_openaip_airport_records(payload):
    if isinstance(payload, list):
        for item in payload:
            yield from iter_openaip_airport_records(item)
        return

    if not isinstance(payload, dict):
        return

    features = payload.get("features")
    if isinstance(features, list):
        for feature in features:
            if not isinstance(feature, dict):
                continue
            record = dict(feature.get("properties") or {})
            for key in ("runways", "rwys"):
                if key in feature and key not in record:
                    record[key] = feature.get(key)
            if "geometry" in feature:
                record["_geometry"] = feature.get("geometry")
            yield from iter_openaip_airport_records(record)
        return

    for key in ("airports", "items", "data", "results"):
        value = payload.get(key)
        if isinstance(value, list):
            for item in value:
                yield from iter_openaip_airport_records(item)
            return

    if isinstance(payload.get("runways") or payload.get("rwys"), list):
        yield payload


def normalise_openaip_airport(record):
    coordinates = openaip_record_coordinates(record)
    if coordinates is None:
        return None

    runways = []
    raw_runways = record.get("runways") or record.get("rwys") or ()
    if isinstance(raw_runways, dict):
        raw_runways = raw_runways.values()
    for runway in raw_runways:
        if not isinstance(runway, dict):
            continue
        length, width = openaip_runway_dimensions(runway)
        if length is None and width is None:
            continue
        label = openaip_runway_label(runway)
        runways.append(
            {
                "label": label,
                "tokens": runway_designator_tokens(label),
                "heading": openaip_runway_heading(runway, label),
                "length_m": length,
                "width_m": width,
            }
        )

    if not runways:
        return None

    return {
        "name": str(record.get("name") or record.get("title") or ""),
        "icao": str(
            record.get("icaoCode")
            or record.get("icao")
            or record.get("icao_code")
            or ""
        ),
        "point": coordinates,
        "runways": tuple(runways),
    }


def openaip_payload_paths():
    paths = []
    for path in TASK_MAP_OPENAIP_AIRPORTS_PATHS:
        if path.is_file():
            paths.append(path)
        elif path.is_dir():
            paths.extend(sorted(path.rglob("*.json")))
            paths.extend(sorted(path.rglob("*.geojson")))
    return tuple(dict.fromkeys(paths))


def load_openaip_airports():
    global _OPENAIP_AIRPORTS
    if _OPENAIP_AIRPORTS is not None:
        return _OPENAIP_AIRPORTS

    airports = []
    for path in openaip_payload_paths():
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
        except Exception as exc:
            print(f"[openaip] skipped {path}: {exc}", file=sys.stderr, flush=True)
            continue

        for record in iter_openaip_airport_records(payload):
            airport = normalise_openaip_airport(record)
            if airport is not None:
                airports.append(airport)

    _OPENAIP_AIRPORTS = tuple(airports)
    if _OPENAIP_AIRPORTS:
        print(
            f"[openaip] loaded {len(_OPENAIP_AIRPORTS)} airports from "
            f"{len(openaip_payload_paths())} file(s)",
            file=sys.stderr,
            flush=True,
        )
    return _OPENAIP_AIRPORTS


def osm_runway_query(bbox):
    query_timeout = max(20, int(TASK_MAP_OVERPASS_TIMEOUT_S))
    return (
        f"[out:json][timeout:{query_timeout}];"
        f'way["aeroway"="runway"]({bbox["south"]:.8f},{bbox["west"]:.8f},'
        f'{bbox["north"]:.8f},{bbox["east"]:.8f});'
        "out geom;"
    )


def fetch_osm_runways(bbox):
    cached = load_cached_runways(bbox)
    if cached is not None:
        features, openaip_count = enrich_runways_with_openaip(cached, bbox)
        return features, "", runway_source_label("cache", openaip_count)

    try:
        features = fetch_osm_runways_from_overpass(bbox)
    except Exception as exc:
        cached = load_cached_runways(bbox)
        if cached is not None:
            features, openaip_count = enrich_runways_with_openaip(cached, bbox)
            return features, str(exc), runway_source_label("cache-after-error", openaip_count)
        raise

    save_cached_runways(bbox, features)
    features, openaip_count = enrich_runways_with_openaip(features, bbox)
    return features, "", runway_source_label("overpass", openaip_count)


def fetch_osm_runways_from_overpass(bbox):
    query = osm_runway_query(bbox)
    data = urllib.parse.urlencode({"data": query}).encode("utf-8")
    last_error = None
    payload = None
    attempts = max(1, TASK_MAP_OVERPASS_ATTEMPTS)
    for _ in range(attempts):
        for url in TASK_MAP_OVERPASS_URLS:
            request = urllib.request.Request(
                url,
                data=data,
                headers={
                    "Content-Type": "application/x-www-form-urlencoded",
                    "User-Agent": "Kigo task map runway fetcher",
                },
            )
            try:
                with urllib.request.urlopen(
                    request,
                    timeout=TASK_MAP_OVERPASS_TIMEOUT_S,
                ) as response:
                    payload = json.loads(response.read().decode("utf-8"))
                break
            except Exception as exc:
                last_error = exc
        if payload is not None:
            break

    if payload is None:
        raise last_error or RuntimeError("no Overpass endpoints configured")

    features = []
    seen = set()
    for element in payload.get("elements", []):
        if not isinstance(element, dict):
            continue
        tags = element.get("tags") or {}
        if tags.get("aeroway") != "runway":
            continue

        points = []
        for point in element.get("geometry") or ():
            if not isinstance(point, dict):
                continue
            lat = point.get("lat")
            lon = point.get("lon")
            if isinstance(lat, (int, float)) and isinstance(lon, (int, float)):
                points.append((float(lon), float(lat)))

        if len(points) < 2:
            continue

        key = tuple((round(lon, 7), round(lat, 7)) for lon, lat in points)
        if key in seen:
            continue
        seen.add(key)
        features.append(
            {
                "label": runway_label(tags),
                "points": points,
                "width_m": runway_width_m(tags),
            }
        )

    return features


def runway_cache_key(bbox):
    text = (
        f"{bbox['south']:.4f},{bbox['west']:.4f},"
        f"{bbox['north']:.4f},{bbox['east']:.4f}"
    )
    return hashlib.sha1(text.encode("ascii")).hexdigest()


def runway_feature_bbox(feature):
    points = feature.get("points") if isinstance(feature, dict) else None
    if not points:
        return None

    lons = [float(point[0]) for point in points]
    lats = [float(point[1]) for point in points]
    return {
        "south": min(lats),
        "west": min(lons),
        "north": max(lats),
        "east": max(lons),
    }


def feature_intersects_bbox(feature, bbox):
    feature_box = runway_feature_bbox(feature)
    if feature_box is None:
        return False
    return not (
        feature_box["east"] < bbox["west"]
        or feature_box["west"] > bbox["east"]
        or feature_box["north"] < bbox["south"]
        or feature_box["south"] > bbox["north"]
    )


def filter_runways_to_bbox(features, bbox):
    return [
        feature
        for feature in features or ()
        if feature_intersects_bbox(feature, bbox)
    ]


def normalise_cached_features(raw):
    features = []
    for feature in raw or ():
        if not isinstance(feature, dict):
            continue
        points = []
        for point in feature.get("points") or ():
            try:
                lon, lat = point
            except Exception:
                continue
            points.append((float(lon), float(lat)))
        if len(points) < 2:
            continue
        features.append(
            {
                "label": str(feature.get("label") or ""),
                "points": points,
                "width_m": float(feature.get("width_m") or 45.0),
                "length_m": feature.get("length_m"),
                "dimensions_source": str(feature.get("dimensions_source") or ""),
            }
        )
    return features


def load_cached_runways(bbox):
    cache_dir = TASK_MAP_RUNWAY_CACHE_DIR
    exact = cache_dir / f"{runway_cache_key(bbox)}.json"
    candidates = [exact]
    if cache_dir.exists():
        candidates.extend(
            path
            for path in sorted(cache_dir.glob("*.json"))
            if path != exact
        )

    for path in candidates:
        try:
            payload = json.loads(path.read_text(encoding="utf-8"))
            cached_bbox = payload.get("bbox")
            if not isinstance(cached_bbox, dict):
                continue
            if not bbox_contains(cached_bbox, bbox):
                continue
            return filter_runways_to_bbox(
                normalise_cached_features(payload.get("features")),
                bbox,
            )
        except Exception:
            continue

    return None


def save_cached_runways(bbox, features):
    try:
        TASK_MAP_RUNWAY_CACHE_DIR.mkdir(parents=True, exist_ok=True)
        payload = {
            "bbox": bbox,
            "features": [
                {
                    "label": feature.get("label") or "",
                    "points": feature.get("points") or [],
                    "width_m": feature.get("width_m") or 45.0,
                    "length_m": feature.get("length_m"),
                    "dimensions_source": feature.get("dimensions_source") or "",
                }
                for feature in features or ()
            ],
        }
        path = TASK_MAP_RUNWAY_CACHE_DIR / f"{runway_cache_key(bbox)}.json"
        path.write_text(json.dumps(payload, separators=(",", ":")), encoding="utf-8")
    except Exception:
        pass


def runway_centerline_points(feature):
    points = feature.get("points") or []
    if len(points) < 2:
        return None

    origin_lon = points[0][0]
    origin_lat = points[0][1]
    mean_lat = sum(point[1] for point in points) / len(points)
    meters_per_lat = 111320.0
    meters_per_lon = max(1.0, meters_per_lat * math.cos(math.radians(mean_lat)))
    xy = [
        (
            (lon - origin_lon) * meters_per_lon,
            (lat - origin_lat) * meters_per_lat,
        )
        for lon, lat in points
    ]

    closed = len(points) >= 4 and points[0] == points[-1]
    if closed:
        ring = xy[:-1]
        if len(ring) < 3:
            return None

        best = None
        for index, start in enumerate(ring):
            end = ring[(index + 1) % len(ring)]
            dx = end[0] - start[0]
            dy = end[1] - start[1]
            length = math.hypot(dx, dy)
            if best is None or length > best[0]:
                best = (length, dx, dy)

        if best is None or best[0] <= 0:
            return None

        length, dx, dy = best
        ux = dx / length
        uy = dy / length
        px = -uy
        py = ux
        axis_values = [x * ux + y * uy for x, y in ring]
        side_values = [x * px + y * py for x, y in ring]
        axis_min = min(axis_values)
        axis_max = max(axis_values)
        side_center = (min(side_values) + max(side_values)) / 2.0
        start_xy = (
            ux * axis_min + px * side_center,
            uy * axis_min + py * side_center,
        )
        end_xy = (
            ux * axis_max + px * side_center,
            uy * axis_max + py * side_center,
        )
    else:
        start_xy = xy[0]
        end_xy = xy[-1]

    if math.hypot(end_xy[0] - start_xy[0], end_xy[1] - start_xy[1]) <= 0:
        return None

    return [
        (
            origin_lon + start_xy[0] / meters_per_lon,
            origin_lat + start_xy[1] / meters_per_lat,
        ),
        (
            origin_lon + end_xy[0] / meters_per_lon,
            origin_lat + end_xy[1] / meters_per_lat,
        ),
    ]


def runway_source_label(base_source, openaip_count):
    if openaip_count:
        return f"{base_source}+openaip:{openaip_count}"
    return base_source


def runway_centerline_measurement(feature):
    points = runway_centerline_points(feature)
    if points is None or len(points) < 2:
        return None

    lon1, lat1 = points[0]
    lon2, lat2 = points[-1]
    mean_lat = (lat1 + lat2) / 2.0
    meters_per_lat = 111320.0
    meters_per_lon = max(1.0, meters_per_lat * math.cos(math.radians(mean_lat)))
    dx = (lon2 - lon1) * meters_per_lon
    dy = (lat2 - lat1) * meters_per_lat
    length = math.hypot(dx, dy)
    if length <= 0:
        return None

    return {
        "points": points,
        "midpoint": ((lon1 + lon2) / 2.0, (lat1 + lat2) / 2.0),
        "heading": math.degrees(math.atan2(dx, dy)) % 180.0,
        "length_m": length,
    }


def openaip_airports_near_bbox(bbox, airports):
    margin = TASK_MAP_OPENAIP_MATCH_RADIUS_M / 111320.0 + 0.05
    south = bbox["south"] - margin
    west = bbox["west"] - margin
    north = bbox["north"] + margin
    east = bbox["east"] + margin
    return tuple(
        airport
        for airport in airports
        if west <= airport["point"][0] <= east and south <= airport["point"][1] <= north
    )


def match_openaip_runway(feature, airports):
    measurement = runway_centerline_measurement(feature)
    if measurement is None:
        return None

    label_tokens = runway_designator_tokens(feature.get("label"))
    best = None
    for airport in airports:
        airport_distance_m = math.sqrt(
            geodesic_distance_sq_m(measurement["midpoint"], airport["point"])
        )
        if airport_distance_m > TASK_MAP_OPENAIP_MATCH_RADIUS_M:
            continue

        single_runway_airport = len(airport["runways"]) == 1
        for runway in airport["runways"]:
            heading_diff = None
            if runway["heading"] is not None:
                heading_diff = angle_diff_180(measurement["heading"], runway["heading"])

            token_match = bool(
                label_tokens and runway["tokens"] and label_tokens.intersection(runway["tokens"])
            )
            token_conflict = bool(label_tokens and runway["tokens"] and not token_match)
            if token_conflict:
                continue

            heading_match = (
                heading_diff is not None
                and heading_diff <= TASK_MAP_OPENAIP_HEADING_TOLERANCE_DEG
            )
            fallback_match = single_runway_airport and not label_tokens
            if not (token_match or heading_match or fallback_match):
                continue

            length_penalty = 0.0
            if runway["length_m"] is not None:
                length_penalty = min(
                    abs(runway["length_m"] - measurement["length_m"]),
                    2000.0,
                ) / 5.0

            score = airport_distance_m + length_penalty
            if heading_diff is not None:
                score += heading_diff * 50.0

            candidate = (score, airport, runway)
            if best is None or candidate[0] < best[0]:
                best = candidate

    if best is None:
        return None

    _, airport, runway = best
    return {
        "airport": airport,
        "runway": runway,
    }


def enrich_runways_with_openaip(features, bbox):
    airports = load_openaip_airports()
    if not airports:
        return list(features or ()), 0

    nearby_airports = openaip_airports_near_bbox(bbox, airports)
    if not nearby_airports:
        return list(features or ()), 0

    enriched = []
    enriched_count = 0
    for feature in features or ():
        match = match_openaip_runway(feature, nearby_airports)
        if match is None:
            enriched.append(feature)
            continue

        runway = match["runway"]
        airport = match["airport"]
        updated = dict(feature)
        if runway["length_m"] is not None:
            updated["length_m"] = runway["length_m"]
        if runway["width_m"] is not None:
            updated["width_m"] = runway["width_m"]
        updated["dimensions_source"] = "openaip"
        updated["openaip_airport"] = airport.get("icao") or airport.get("name") or ""
        updated["openaip_runway"] = runway.get("label") or ""
        if not updated.get("label") and runway.get("label"):
            updated["label"] = runway.get("label")
        enriched.append(updated)
        enriched_count += 1

    return enriched, enriched_count


def valid_feature_length_m(feature):
    length = numeric_meters(feature.get("length_m") if isinstance(feature, dict) else None)
    if length is None or not 20 <= length <= 8000:
        return None
    return length


def runway_sized_centerline_points(feature):
    measurement = runway_centerline_measurement(feature)
    if measurement is None:
        return None

    length_m = valid_feature_length_m(feature)
    if length_m is None:
        return measurement["points"]

    (lon1, lat1), (lon2, lat2) = measurement["points"]
    mean_lat = (lat1 + lat2) / 2.0
    meters_per_lat = 111320.0
    meters_per_lon = max(1.0, meters_per_lat * math.cos(math.radians(mean_lat)))
    dx = (lon2 - lon1) * meters_per_lon
    dy = (lat2 - lat1) * meters_per_lat
    current_length = math.hypot(dx, dy)
    if current_length <= 0:
        return measurement["points"]

    ux = dx / current_length
    uy = dy / current_length
    center_x = ((lon1 + lon2) / 2.0 - lon1) * meters_per_lon
    center_y = ((lat1 + lat2) / 2.0 - lat1) * meters_per_lat
    half_length = length_m / 2.0
    start_x = center_x - ux * half_length
    start_y = center_y - uy * half_length
    end_x = center_x + ux * half_length
    end_y = center_y + uy * half_length

    return [
        (lon1 + start_x / meters_per_lon, lat1 + start_y / meters_per_lat),
        (lon1 + end_x / meters_per_lon, lat1 + end_y / meters_per_lat),
    ]


def runway_draw_width_m(feature):
    width_m = numeric_meters(feature.get("width_m") if isinstance(feature, dict) else None)
    if width_m is None or not 1 <= width_m <= 300:
        width_m = 45.0

    if isinstance(feature, dict) and feature.get("dimensions_source") == "openaip":
        return width_m

    return max(width_m, TASK_MAP_RUNWAY_VISIBLE_WIDTH_M)


def runway_centerline_feature(feature):
    points = runway_sized_centerline_points(feature)
    if points is None:
        return None
    return {
        "label": "",
        "points": points,
        "width_m": feature.get("width_m") or 45.0,
    }


def runway_area_polygon(feature):
    points = runway_sized_centerline_points(feature)
    if points is None or len(points) < 2:
        return None

    lon1, lat1 = points[0]
    lon2, lat2 = points[-1]
    mean_lat = (lat1 + lat2) / 2.0
    meters_per_lat = 111320.0
    meters_per_lon = max(1.0, meters_per_lat * math.cos(math.radians(mean_lat)))
    dx = (lon2 - lon1) * meters_per_lon
    dy = (lat2 - lat1) * meters_per_lat
    length = math.hypot(dx, dy)
    if length <= 0:
        return None

    width_m = runway_draw_width_m(feature)
    half_width = width_m / 2.0
    ux = -dy / length
    uy = dx / length
    dlon = ux * half_width / meters_per_lon
    dlat = uy * half_width / meters_per_lat

    polygon = [
        (lon1 + dlon, lat1 + dlat),
        (lon2 + dlon, lat2 + dlat),
        (lon2 - dlon, lat2 - dlat),
        (lon1 - dlon, lat1 - dlat),
        (lon1 + dlon, lat1 + dlat),
    ]
    return {"label": "", "points": polygon}


def runway_polygon_layers(features):
    polygons = []
    for feature in features or ():
        polygon = runway_area_polygon(feature)
        if polygon is not None:
            polygons.append(polygon)

    if not polygons:
        return {}

    return {"runway_area": polygons}


def runway_polyline_layers(features):
    centerlines = []
    for feature in features or ():
        centerline = runway_centerline_feature(feature)
        if centerline is not None:
            centerlines.append(centerline)

    layers = {}
    if centerlines:
        layers["runway_line"] = centerlines

    label_lines = runway_label_line_features(features)
    if label_lines:
        layers["runway_label_line"] = label_lines

    return layers


def runway_threshold_tokens(feature):
    tokens = ()
    for value in (
        feature.get("label") if isinstance(feature, dict) else "",
        feature.get("openaip_runway") if isinstance(feature, dict) else "",
    ):
        tokens = ordered_runway_designator_tokens(value)
        if tokens:
            break

    if len(tokens) == 1:
        opposite = opposite_runway_designator(tokens[0])
        if opposite and opposite not in tokens:
            tokens = (tokens[0], opposite)

    return tokens[:2]


def runway_threshold_label_points(feature):
    points = runway_sized_centerline_points(feature)
    if points is None or len(points) < 2:
        return []

    token_headings = []
    for token in runway_threshold_tokens(feature):
        heading = runway_designator_heading_360(token)
        if heading is not None:
            token_headings.append((token, heading))
    if not token_headings:
        return []

    (lon1, lat1), (lon2, lat2) = points[0], points[-1]
    mean_lat = (lat1 + lat2) / 2.0
    meters_per_lat = 111320.0
    meters_per_lon = max(1.0, meters_per_lat * math.cos(math.radians(mean_lat)))
    dx = (lon2 - lon1) * meters_per_lon
    dy = (lat2 - lat1) * meters_per_lat
    length = math.hypot(dx, dy)
    if length <= 0:
        return []

    ux = dx / length
    uy = dy / length
    start_heading = math.degrees(math.atan2(dx, dy)) % 360.0
    end_heading = (start_heading + 180.0) % 360.0
    labels = [None, None]
    remaining = list(token_headings)
    for endpoint_index, endpoint_heading in ((0, start_heading), (1, end_heading)):
        if not remaining:
            break
        best_index = min(
            range(len(remaining)),
            key=lambda index: angle_diff_360(remaining[index][1], endpoint_heading),
        )
        labels[endpoint_index] = remaining.pop(best_index)[0]

    offset_m = max(65.0, runway_draw_width_m(feature) * 0.6)

    def project(local_x, local_y):
        return (
            lon1 + local_x / meters_per_lon,
            lat1 + local_y / meters_per_lat,
        )

    label_points = []
    if labels[0]:
        label_points.append(
            {
                "label": labels[0],
                "point": project(-ux * offset_m, -uy * offset_m),
            }
        )
    if labels[1]:
        label_points.append(
            {
                "label": labels[1],
                "point": project(dx + ux * offset_m, dy + uy * offset_m),
            }
        )
    return label_points


RUNWAY_DIGIT_SEGMENTS = {
    "0": ("a", "b", "c", "d", "e", "f"),
    "1": ("b", "c"),
    "2": ("a", "b", "g", "e", "d"),
    "3": ("a", "b", "g", "c", "d"),
    "4": ("f", "g", "b", "c"),
    "5": ("a", "f", "g", "c", "d"),
    "6": ("a", "f", "g", "e", "c", "d"),
    "7": ("a", "b", "c"),
    "8": ("a", "b", "c", "d", "e", "f", "g"),
    "9": ("a", "b", "c", "d", "f", "g"),
}


def runway_digit_segment_points(segment, width_m, height_m):
    x0 = -width_m / 2.0
    x1 = width_m / 2.0
    y0 = -height_m / 2.0
    y1 = height_m / 2.0
    ym = 0.0
    return {
        "a": ((x0, y1), (x1, y1)),
        "b": ((x1, y1), (x1, ym)),
        "c": ((x1, ym), (x1, y0)),
        "d": ((x0, y0), (x1, y0)),
        "e": ((x0, ym), (x0, y0)),
        "f": ((x0, y1), (x0, ym)),
        "g": ((x0, ym), (x1, ym)),
    }.get(segment)


def runway_label_line_polylines(label, center):
    if center is None:
        return []

    digits = "".join(ch for ch in str(label or "") if ch.isdigit())
    if len(digits) < 2:
        return []
    digits = digits[:2]

    height_m = max(20.0, TASK_MAP_RUNWAY_LABEL_HEIGHT_M)
    width_m = height_m * 0.42
    gap_m = height_m * 0.18
    total_width_m = len(digits) * width_m + (len(digits) - 1) * gap_m
    meters_per_lat = 111320.0
    meters_per_lon = max(1.0, meters_per_lat * math.cos(math.radians(center[1])))

    def project(dx_m, dy_m):
        return (
            center[0] + dx_m / meters_per_lon,
            center[1] + dy_m / meters_per_lat,
        )

    lines = []
    start_x = -total_width_m / 2.0 + width_m / 2.0
    for digit_index, digit in enumerate(digits):
        digit_center_x = start_x + digit_index * (width_m + gap_m)
        for segment in RUNWAY_DIGIT_SEGMENTS.get(digit, ()):
            endpoints = runway_digit_segment_points(segment, width_m, height_m)
            if endpoints is None:
                continue
            (x1, y1), (x2, y2) = endpoints
            lines.append(
                {
                    "label": "",
                    "points": [
                        project(digit_center_x + x1, y1),
                        project(digit_center_x + x2, y2),
                    ],
                }
            )

    return lines


def runway_label_line_features(features):
    lines = []
    for feature in features or ():
        for item in runway_threshold_label_points(feature):
            lines.extend(runway_label_line_polylines(item.get("label"), item.get("point")))
    return lines


def runway_point_layers(features):
    label_points = []
    for feature in features or ():
        label_points.extend(runway_threshold_label_points(feature))

    if not label_points:
        return {}
    return {"runway_label_point": label_points}


def dbf_field_specs(data: bytes):
    if len(data) < 32:
        return [], 0, 0, b""
    header_len = struct.unpack_from("<H", data, 8)[0]
    record_len = struct.unpack_from("<H", data, 10)[0]
    fields = []
    offset = 32
    while offset + 32 <= header_len and data[offset] != 0x0D:
        raw = data[offset:offset + 32]
        name = raw[:11].split(b"\0", 1)[0].decode("latin1", errors="replace").strip()
        length = raw[16]
        fields.append((name, length))
        offset += 32
    return fields, header_len, record_len, data[32:header_len]


def dbf_field_layout(data: bytes):
    if len(data) < 32:
        return [], 0, 0
    header_len = struct.unpack_from("<H", data, 8)[0]
    record_len = struct.unpack_from("<H", data, 10)[0]
    fields = []
    field_offset = 1
    offset = 32
    while offset + 32 <= header_len and data[offset] != 0x0D:
        raw = data[offset:offset + 32]
        name = raw[:11].split(b"\0", 1)[0].decode("latin1", errors="replace").strip()
        field_type = chr(raw[11]) if raw[11] else ""
        length = raw[16]
        fields.append(
            {
                "name": name,
                "type": field_type,
                "offset": field_offset,
                "length": length,
            }
        )
        field_offset += length
        offset += 32
    return fields, header_len, record_len


def dbf_rows(data: bytes):
    fields, header_len, record_len, _ = dbf_field_specs(data)
    if not fields or record_len <= 0:
        return []
    count = struct.unpack_from("<I", data, 4)[0]
    rows = []
    for index in range(count):
        start = header_len + index * record_len
        row = data[start:start + record_len]
        if len(row) != record_len:
            break
        rows.append(row)
    return rows


def dbf_value(row: bytes, fields, key: str) -> str:
    position = 1
    for name, length in fields:
        value = row[position:position + length]
        if name.lower() == key.lower():
            return value.decode("latin1", errors="replace").strip()
        position += length
    return ""


def point_record_xy(content: bytes):
    if len(content) < 20:
        return None
    shape_type = struct.unpack_from("<i", content, 0)[0]
    if shape_type != 1:
        return None
    return struct.unpack_from("<dd", content, 4)


def shp_records(data: bytes):
    if len(data) < 100:
        return b"", []
    header = data[:100]
    offset = 100
    records = []
    while offset + 8 <= len(data):
        _, length_words = struct.unpack_from(">ii", data, offset)
        offset += 8
        content = data[offset:offset + length_words * 2]
        offset += length_words * 2
        bbox = crop.shp_record_bbox(content)
        records.append({"content": content, "length_words": length_words, "bbox": bbox})
    return header, records


def geodesic_distance_sq_m(a, b):
    lon1, lat1 = a
    lon2, lat2 = b
    mean_lat = math.radians((lat1 + lat2) / 2.0)
    meters_per_lat = 111320.0
    meters_per_lon = meters_per_lat * max(0.01, math.cos(mean_lat))
    dx = (lon1 - lon2) * meters_per_lon
    dy = (lat1 - lat2) * meters_per_lat
    return dx * dx + dy * dy


def parse_population(value: str) -> int:
    try:
        return int(float(str(value or "0").replace(",", ".")))
    except ValueError:
        return 0


def thin_label_point_layers(layer_payloads, min_distance_m: float):
    candidates = []
    for layer_name, payload in layer_payloads.items():
        fields, _, _, _ = dbf_field_specs(payload["dbf"])
        rows = dbf_rows(payload["dbf"])
        for index, record in enumerate(payload["records"]):
            if index >= len(rows):
                continue
            xy = point_record_xy(record["content"])
            if xy is None:
                continue
            row = rows[index]
            candidates.append(
                {
                    "layer": layer_name,
                    "index": index,
                    "xy": xy,
                    "name": dbf_value(row, fields, "name"),
                    "population": parse_population(dbf_value(row, fields, "population")),
                    "priority": TASK_MAP_LABEL_LAYER_PRIORITY.get(layer_name, 99),
                }
            )

    candidates.sort(
        key=lambda item: (
            item["priority"],
            -item["population"],
            item["name"],
            item["index"],
        )
    )

    keep = {layer_name: set() for layer_name in layer_payloads}
    accepted_by_layer = {layer_name: [] for layer_name in layer_payloads}
    min_distance_sq = min_distance_m * min_distance_m
    for candidate in candidates:
        accepted = accepted_by_layer.setdefault(candidate["layer"], [])
        if any(geodesic_distance_sq_m(candidate["xy"], chosen["xy"]) < min_distance_sq
               for chosen in accepted):
            continue
        accepted.append(candidate)
        keep[candidate["layer"]].add(candidate["index"])

    accepted_count = sum(len(rows) for rows in accepted_by_layer.values())
    return keep, len(candidates), len(candidates) - accepted_count


def build_shp_bytes(header: bytes, records):
    length_words = (100 + sum(8 + len(record["content"]) for record in records)) // 2
    out = bytearray(crop.update_shp_header(header, length_words, records))
    for number, record in enumerate(records, 1):
        out.extend(struct.pack(">ii", number, record["length_words"]))
        out.extend(record["content"])
    return bytes(out)


def build_shx_bytes(header: bytes, records):
    length_words = (100 + len(records) * 8) // 2
    out = bytearray(crop.update_shp_header(header, length_words, records))
    offset_words = 50
    for record in records:
        out.extend(struct.pack(">ii", offset_words, record["length_words"]))
        offset_words += 4 + record["length_words"]
    return bytes(out)


def build_dbf_bytes(dbf: bytes, keep_indices):
    if len(dbf) < 32:
        return dbf
    fields, header_len, record_len, rest_header = dbf_field_specs(dbf)
    if not fields or record_len <= 0:
        return dbf
    rows = dbf_rows(dbf)
    selected = [row for index, row in enumerate(rows) if index in keep_indices]
    header = bytearray(dbf[:32])
    struct.pack_into("<I", header, 4, len(selected))
    return bytes(header) + rest_header + b"".join(selected) + b"\x1a"


def blank_dbf_name_fields(dbf: bytes):
    if len(dbf) < 32:
        return dbf, 0

    fields, header_len, record_len, _ = dbf_field_specs(dbf)
    if not fields or record_len <= 0:
        return dbf, 0

    targets = []
    position = 1
    for name, length in fields:
        if name.lower() == "name":
            targets.append((position, length))
        position += length

    if not targets:
        return dbf, 0

    out = bytearray(dbf)
    count = struct.unpack_from("<I", dbf, 4)[0]
    changed = 0
    for index in range(count):
        start = header_len + index * record_len
        end = start + record_len
        if end > len(out):
            break
        if out[start:start + 1] == b"*":
            continue

        changed_row = False
        for offset, length in targets:
            field_start = start + offset
            field_end = field_start + length
            if bytes(out[field_start:field_end]).strip():
                out[field_start:field_end] = b" " * length
                changed_row = True
        if changed_row:
            changed += 1

    return bytes(out), changed


RUNWAY_PAIR_LABEL_RE = re.compile(
    r"^\s*(?:RWY\s*)?([0-3]?\d[LCR]?)\s*[/\\-]\s*([0-3]?\d[LCR]?)\s*$",
    re.IGNORECASE,
)


def is_runway_pair_label(value: str) -> bool:
    text = str(value or "").strip()
    if not RUNWAY_PAIR_LABEL_RE.match(text):
        return False
    return len(ordered_runway_designator_tokens(text)) >= 2


def blank_runway_pair_label_fields(dbf: bytes):
    if len(dbf) < 32:
        return dbf, 0

    fields, header_len, record_len, _ = dbf_field_specs(dbf)
    if not fields or record_len <= 0:
        return dbf, 0

    field_offsets = []
    position = 1
    for _, length in fields:
        field_offsets.append((position, length))
        position += length

    out = bytearray(dbf)
    count = struct.unpack_from("<I", dbf, 4)[0]
    changed = 0
    for index in range(count):
        start = header_len + index * record_len
        end = start + record_len
        if end > len(out):
            break
        if out[start:start + 1] == b"*":
            continue

        for offset, length in field_offsets:
            field_start = start + offset
            field_end = field_start + length
            raw_value = bytes(out[field_start:field_end])
            value = raw_value.decode("latin1", errors="replace").strip()
            if not is_runway_pair_label(value):
                continue
            out[field_start:field_end] = b" " * length
            changed += 1

    return bytes(out), changed


def dbf_output_ldid():
    raw = os.environ.get("KIGO_TASK_MAP_DBF_OUTPUT_LDID", "200").strip()
    if not raw:
        return None
    try:
        value = int(raw, 0)
    except ValueError:
        return None
    if 0 <= value <= 255:
        return value
    return None


def encode_dbf_text_to_field(text: str, encoding: str, length: int) -> bytes:
    text = text.rstrip()
    while text:
        encoded = text.encode(encoding, errors="replace")
        if len(encoded) <= length:
            return encoded.ljust(length, b" ")
        text = text[:-1]
    return b" " * length


def recode_dbf_text_fields(dbf: bytes, encoding: str):
    fields, header_len, record_len = dbf_field_layout(dbf)
    if not fields or record_len <= 0:
        return dbf, {"records": 0, "fields": 0}

    out = bytearray(dbf)
    ldid = dbf_output_ldid()
    if ldid is not None and len(out) > 29:
        out[29] = ldid

    count = struct.unpack_from("<I", dbf, 4)[0]
    changed_records = 0
    changed_fields = 0
    text_fields = [field for field in fields if field["type"].upper() == "C"]

    for index in range(count):
        start = header_len + index * record_len
        end = start + record_len
        if end > len(out):
            break
        if out[start:start + 1] == b"*":
            continue

        changed_row = False
        for field in text_fields:
            field_start = start + field["offset"]
            field_end = field_start + field["length"]
            raw_value = bytes(out[field_start:field_end])
            if not raw_value.strip():
                continue

            try:
                text = raw_value.rstrip(b" \0").decode("utf-8")
            except UnicodeDecodeError:
                continue

            encoded = encode_dbf_text_to_field(text, encoding, field["length"])
            if encoded == raw_value:
                continue

            out[field_start:field_end] = encoded
            changed_row = True
            changed_fields += 1

        if changed_row:
            changed_records += 1

    return bytes(out), {"records": changed_records, "fields": changed_fields}


def rewrite_xcm_dbf_encoding(xcm_bytes: bytes):
    if not TASK_MAP_DBF_OUTPUT_ENCODING:
        return xcm_bytes, {}

    cpg_payload = (TASK_MAP_DBF_OUTPUT_CPG.rstrip() + "\n").encode("ascii", errors="replace")
    with tempfile.TemporaryDirectory(prefix="kigo_dbf_encoding_") as tmp:
        src_path = Path(tmp) / "src.xcm"
        dst_path = Path(tmp) / "dst.xcm"
        src_path.write_bytes(xcm_bytes)

        replacements = {}
        stats = {"encoding": TASK_MAP_DBF_OUTPUT_ENCODING, "layers": {}}
        with zipfile.ZipFile(src_path) as zin:
            names = set(zin.namelist())
            for info in zin.infolist():
                if not info.filename.lower().endswith(".dbf"):
                    continue

                recoded, layer_stats = recode_dbf_text_fields(
                    zin.read(info.filename),
                    TASK_MAP_DBF_OUTPUT_ENCODING,
                )
                cpg_name = info.filename[:-4] + ".cpg"
                cpg_changed = cpg_name not in names or zin.read(cpg_name) != cpg_payload
                if layer_stats["fields"] > 0 or cpg_changed:
                    replacements[info.filename] = recoded
                    replacements[cpg_name] = cpg_payload
                    stats["layers"][Path(info.filename).stem] = layer_stats

            if not replacements:
                return xcm_bytes, {}

            written = set()
            with zipfile.ZipFile(dst_path, "w") as zout:
                for info in zin.infolist():
                    if info.filename in replacements:
                        new_info = zipfile.ZipInfo(info.filename, date_time=info.date_time)
                        new_info.external_attr = info.external_attr
                        new_info.compress_type = info.compress_type
                        zout.writestr(new_info, replacements[info.filename])
                        written.add(info.filename)
                        continue
                    new_info = zipfile.ZipInfo(info.filename, date_time=info.date_time)
                    new_info.external_attr = info.external_attr
                    new_info.compress_type = info.compress_type
                    with zin.open(info) as src, zout.open(new_info, "w") as dst:
                        shutil.copyfileobj(src, dst, length=1024 * 1024)
                    written.add(info.filename)

                for name, payload in replacements.items():
                    if name in written:
                        continue
                    new_info = zipfile.ZipInfo(name)
                    new_info.compress_type = zipfile.ZIP_DEFLATED
                    zout.writestr(new_info, payload)

        return dst_path.read_bytes(), stats


def rewrite_topology_template_bytes(
    topology: bytes,
    forced_rows: dict[str, str],
    available_stems: set[str],
):
    changed = {}
    written = set()
    out = []

    try:
        text = topology.decode("utf-8")
    except UnicodeDecodeError:
        text = topology.decode("latin1", errors="replace")

    for line in text.splitlines(keepends=True):
        stripped = line.strip()
        if stripped and not stripped.startswith("*"):
            try:
                row = next(csv.reader([line]))
            except Exception:
                row = []

            if row:
                stem = row[0].strip().lower()
                forced = forced_rows.get(stem)
                if forced and stem in available_stems:
                    forced_line = forced.rstrip() + "\n"
                    if forced_line != line:
                        changed[stem] = "updated"
                    out.append(forced_line)
                    written.add(stem)
                    continue

        out.append(line)

    for stem, forced in forced_rows.items():
        if stem in written or stem not in available_stems:
            continue
        out.append(forced.rstrip() + "\n")
        changed[stem] = "added"

    if not changed:
        return topology, {}

    return "".join(out).encode("utf-8"), changed


def rewrite_xcm_with_thinned_labels(xcm_bytes: bytes):
    if (
        TASK_MAP_LABEL_SPACING_M <= 0
        and not TASK_MAP_SUPPRESSED_NAME_LAYERS
        and not TASK_MAP_LABEL_TOPOLOGY_ROWS
    ):
        return xcm_bytes, {}

    with tempfile.TemporaryDirectory(prefix="kigo_label_thin_") as tmp:
        src_path = Path(tmp) / "src.xcm"
        dst_path = Path(tmp) / "dst.xcm"
        src_path.write_bytes(xcm_bytes)

        with zipfile.ZipFile(src_path) as zin:
            names = set(zin.namelist())
            layer_payloads = {}
            for layer_name in TASK_MAP_LABEL_POINT_LAYERS:
                required = {f"{layer_name}.shp", f"{layer_name}.shx", f"{layer_name}.dbf"}
                if not required.issubset(names):
                    continue
                header, records = shp_records(zin.read(f"{layer_name}.shp"))
                layer_payloads[layer_name] = {
                    "header": header,
                    "records": records,
                    "dbf": zin.read(f"{layer_name}.dbf"),
                    "shx": zin.read(f"{layer_name}.shx"),
                }

            replacements = {}
            changed_layers = set()
            stats = {}
            available_stems = {
                Path(name).stem.lower()
                for name in names
                if name.lower().endswith(".shp")
            }

            if "topology.tpl" in names:
                topology, topology_changed = rewrite_topology_template_bytes(
                    zin.read("topology.tpl"),
                    TASK_MAP_LABEL_TOPOLOGY_ROWS,
                    available_stems,
                )
                if topology_changed:
                    replacements["topology.tpl"] = topology
                    stats["topology_rows"] = topology_changed

            if layer_payloads and TASK_MAP_LABEL_SPACING_M > 0:
                keep, total, removed = thin_label_point_layers(
                    layer_payloads,
                    TASK_MAP_LABEL_SPACING_M,
                )
                stats.update({"total": total, "removed": removed, "layers": {}})
                for layer_name, payload in layer_payloads.items():
                    keep_indices = keep.get(layer_name, set())
                    records = [
                        record
                        for index, record in enumerate(payload["records"])
                        if index in keep_indices
                    ]
                    before = len(payload["records"])
                    after = len(records)
                    if before == after:
                        continue
                    changed_layers.add(layer_name)
                    stats["layers"][layer_name] = {"before": before, "after": after}
                    replacements[f"{layer_name}.shp"] = build_shp_bytes(payload["header"], records)
                    replacements[f"{layer_name}.shx"] = build_shx_bytes(payload["header"], records)
                    replacements[f"{layer_name}.dbf"] = build_dbf_bytes(payload["dbf"], keep_indices)

            suppressed = {}
            for layer_name in TASK_MAP_SUPPRESSED_NAME_LAYERS:
                dbf_name = f"{layer_name}.dbf"
                if dbf_name not in names:
                    continue
                dbf = replacements.get(dbf_name)
                if dbf is None:
                    dbf = zin.read(dbf_name)
                cleaned, changed = blank_dbf_name_fields(dbf)
                if changed <= 0:
                    continue
                replacements[dbf_name] = cleaned
                suppressed[layer_name] = changed

            if suppressed:
                stats["suppressed_names"] = suppressed

            if not replacements:
                return xcm_bytes, stats

            with zipfile.ZipFile(dst_path, "w", compression=zipfile.ZIP_STORED) as zout:
                for info in zin.infolist():
                    if info.filename in replacements:
                        new_info = zipfile.ZipInfo(info.filename, date_time=info.date_time)
                        new_info.external_attr = info.external_attr
                        new_info.compress_type = zipfile.ZIP_STORED
                        zout.writestr(new_info, replacements[info.filename])
                        continue
                    if any(info.filename == f"{layer}.qix" for layer in changed_layers):
                        continue
                    new_info = zipfile.ZipInfo(info.filename, date_time=info.date_time)
                    new_info.external_attr = info.external_attr
                    new_info.compress_type = zipfile.ZIP_STORED
                    with zin.open(info) as src, zout.open(new_info, "w") as dst:
                        shutil.copyfileobj(src, dst, length=1024 * 1024)

        return dst_path.read_bytes(), stats


def strip_runway_pair_labels_from_xcm(xcm_bytes: bytes):
    with tempfile.TemporaryDirectory(prefix="kigo_runway_label_strip_") as tmp:
        src_path = Path(tmp) / "src.xcm"
        dst_path = Path(tmp) / "dst.xcm"
        src_path.write_bytes(xcm_bytes)

        replacements = {}
        stats = {}
        with zipfile.ZipFile(src_path) as zin:
            for info in zin.infolist():
                if not info.filename.lower().endswith(".dbf"):
                    continue
                cleaned, changed = blank_runway_pair_label_fields(zin.read(info.filename))
                if changed <= 0:
                    continue
                replacements[info.filename] = cleaned
                stats[Path(info.filename).stem] = changed

            if not replacements:
                return xcm_bytes, {}

            with zipfile.ZipFile(dst_path, "w", compression=zipfile.ZIP_STORED) as zout:
                for info in zin.infolist():
                    if info.filename in replacements:
                        new_info = zipfile.ZipInfo(info.filename, date_time=info.date_time)
                        new_info.external_attr = info.external_attr
                        new_info.compress_type = zipfile.ZIP_STORED
                        zout.writestr(new_info, replacements[info.filename])
                        continue
                    new_info = zipfile.ZipInfo(info.filename, date_time=info.date_time)
                    new_info.external_attr = info.external_attr
                    new_info.compress_type = zipfile.ZIP_STORED
                    with zin.open(info) as src, zout.open(new_info, "w") as dst:
                        shutil.copyfileobj(src, dst, length=1024 * 1024)

        return dst_path.read_bytes(), stats


def postprocess_task_xcm(raw: bytes, context: str):
    try:
        raw, label_stats = rewrite_xcm_with_thinned_labels(raw)
        if label_stats:
            print(
                f"[{context}] label thinning stats={json.dumps(label_stats, sort_keys=True)}",
                file=sys.stderr,
                flush=True,
            )
    except Exception as exc:
        print(
            f"[{context}] label thinning failed (returning unthinned map): {exc}",
            file=sys.stderr,
            flush=True,
        )

    try:
        raw, strip_stats = strip_runway_pair_labels_from_xcm(raw)
        if strip_stats:
            print(
                f"[{context}] stripped runway pair labels={json.dumps(strip_stats, sort_keys=True)}",
                file=sys.stderr,
                flush=True,
            )
    except Exception as exc:
        print(
            f"[{context}] runway pair label strip failed (returning unstripped map): {exc}",
            file=sys.stderr,
            flush=True,
        )

    try:
        raw, encoding_stats = rewrite_xcm_dbf_encoding(raw)
        if encoding_stats:
            print(
                f"[{context}] dbf encoding stats={json.dumps(encoding_stats, sort_keys=True)}",
                file=sys.stderr,
                flush=True,
            )
    except Exception as exc:
        print(
            f"[{context}] dbf encoding rewrite failed (returning original encoding): {exc}",
            file=sys.stderr,
            flush=True,
        )

    return raw


def validate_bbox(bbox):
    if bbox["south"] >= bbox["north"]:
        raise ValueError("bbox.south must be less than bbox.north")
    if bbox["west"] >= bbox["east"]:
        raise ValueError("bbox.west must be less than bbox.east")
    if bbox["south"] < -90 or bbox["north"] > 90:
        raise ValueError("bbox latitude values must be within -90..90")


def bbox_contains(outer, inner) -> bool:
    epsilon = 1e-9
    return (
        outer["south"] <= inner["south"] + epsilon
        and outer["west"] <= inner["west"] + epsilon
        and outer["north"] >= inner["north"] - epsilon
        and outer["east"] >= inner["east"] - epsilon
    )


def bbox_intersects(a, b) -> bool:
    return not (
        a["east"] < b["west"]
        or a["west"] > b["east"]
        or a["north"] < b["south"]
        or a["south"] > b["north"]
    )


def bbox_overlaps_area(a, b, epsilon: float = 1e-9) -> bool:
    return (
        min(a["east"], b["east"]) - max(a["west"], b["west"]) > epsilon
        and min(a["north"], b["north"]) - max(a["south"], b["south"]) > epsilon
    )


def bbox_union(boxes):
    boxes = list(boxes)
    if not boxes:
        return None
    return {
        "south": min(box["south"] for box in boxes),
        "west": min(box["west"] for box in boxes),
        "north": max(box["north"] for box in boxes),
        "east": max(box["east"] for box in boxes),
    }


def bbox_area_key(bbox):
    return max(0.0, bbox["north"] - bbox["south"]) * max(0.0, bbox["east"] - bbox["west"])


def bbox_header_text(bbox) -> str:
    return (
        f"{bbox['south']:.8f},{bbox['west']:.8f},"
        f"{bbox['north']:.8f},{bbox['east']:.8f}"
    )


def select_base_map(base_maps: tuple[BaseMap, ...], bbox) -> BaseMap:
    matching = []
    for base_map in base_maps:
        if not bbox_contains(base_map.bbox, bbox):
            continue
        if base_map.topology_bbox is None or not bbox_contains(base_map.topology_bbox, bbox):
            print(
                f"[base-map] {base_map.path.name}: terrain OK but topology "
                f"S={base_map.topology_bbox['south'] if base_map.topology_bbox else 'n/a':.4f} "
                f"does not cover task S={bbox['south']:.4f} — skipping",
                file=sys.stderr, flush=True,
            )
            continue
        matching.append((bbox_area_key(base_map.bbox), base_map))

    if matching:
        return min(matching, key=lambda item: item[0])[1]

    formatted = (
        f"{bbox['south']:.6f},{bbox['west']:.6f},"
        f"{bbox['north']:.6f},{bbox['east']:.6f}"
    )
    raise ValueError(f"no base map covers requested bbox {formatted}")


def load_source_tiles() -> tuple[SourceTile, ...]:
    manifest_path = TASK_MAP_SOURCE_REPO / "manifest"
    if not manifest_path.exists():
        return ()
    manifest = json.loads(manifest_path.read_text(encoding="utf-8"))
    datasets = manifest.get("topology", {}).get("datasets", {}).get("osm", [])
    tiles = []
    for dataset in datasets:
        name = str(dataset.get("name") or "")
        bounds = dataset.get("bounds")
        if not name or not isinstance(bounds, list) or len(bounds) != 4:
            continue
        left, right, top, bottom = (float(value) for value in bounds)
        tiles.append(
            SourceTile(
                name=name,
                bbox={"south": bottom, "west": left, "north": top, "east": right},
            )
        )
    return tuple(tiles)


def source_repo_fingerprint() -> str:
    digest = hashlib.sha1()
    digest.update(TASK_MAP_XCM_CACHE_VERSION.encode("ascii"))
    digest.update(b"pol-highres-base-crop-3arcsec-topo")
    digest.update(f"runway-width:{TASK_MAP_RUNWAY_VISIBLE_WIDTH_M:.3f}".encode("ascii"))
    tiles = load_source_tiles()
    if not tiles:
        digest.update(b"tile-grid:missing")
    for tile in sorted(tiles, key=lambda item: item.name):
        digest.update(tile.name.encode("utf-8"))
        digest.update(
            ",".join(f"{tile.bbox[key]:.8f}" for key in ("south", "west", "north", "east"))
            .encode("ascii")
        )
    return digest.hexdigest()


def select_source_tile_cache(required_bbox):
    tiles = load_source_tiles()
    if not tiles:
        return None

    selected = [tile for tile in tiles if bbox_overlaps_area(tile.bbox, required_bbox)]
    if not selected:
        return None

    union = bbox_union(tile.bbox for tile in selected)
    if union is None or not bbox_contains(union, required_bbox):
        return None
    if len(selected) > TASK_MAP_TILE_CACHE_MAX_TILES:
        return None
    return tuple(sorted(selected, key=lambda tile: tile.name)), union


def xcm_cache_digest(kind: str, source_key: str, bbox, tile_names=()) -> str:
    payload = {
        "version": TASK_MAP_XCM_CACHE_VERSION,
        "kind": kind,
        "source_key": source_key,
        "bbox": {key: round(float(value), 8) for key, value in sorted(bbox.items())},
        "tiles": list(tile_names),
        "runway_width_m": TASK_MAP_RUNWAY_VISIBLE_WIDTH_M,
    }
    text = json.dumps(payload, sort_keys=True, separators=(",", ":"))
    return hashlib.sha1(text.encode("utf-8")).hexdigest()


def xcm_cache_paths(cache_key: str):
    return (
        TASK_MAP_XCM_CACHE_DIR / f"{cache_key}.xcm",
        TASK_MAP_XCM_CACHE_DIR / f"{cache_key}.json",
    )


def read_cached_xcm(cache_key: str):
    xcm_path, meta_path = xcm_cache_paths(cache_key)
    if not xcm_path.exists() or not meta_path.exists():
        return None
    try:
        metadata = json.loads(meta_path.read_text(encoding="utf-8"))
        if metadata.get("version") != TASK_MAP_XCM_CACHE_VERSION:
            return None
        return xcm_path.read_bytes(), metadata, xcm_path
    except Exception:
        return None


def find_covering_cached_xcm(required_bbox, source_key: str):
    if not TASK_MAP_XCM_CACHE_DIR.exists():
        return None

    candidates = []
    required_area = bbox_area_key(required_bbox)
    max_area = (
        required_area * TASK_MAP_COVERING_CACHE_MAX_AREA_RATIO
        if required_area > 0
        else 0.0
    )
    for meta_path in TASK_MAP_XCM_CACHE_DIR.glob("*.json"):
        try:
            metadata = json.loads(meta_path.read_text(encoding="utf-8"))
            if metadata.get("version") != TASK_MAP_XCM_CACHE_VERSION:
                continue
            if metadata.get("source_key") != source_key:
                continue
            cached_bbox = metadata.get("bbox")
            if not isinstance(cached_bbox, dict) or not bbox_contains(cached_bbox, required_bbox):
                continue
            cached_area = bbox_area_key(cached_bbox)
            if required_area > 0 and cached_area > max_area:
                continue
            xcm_path = TASK_MAP_XCM_CACHE_DIR / f"{meta_path.stem}.xcm"
            if not xcm_path.exists():
                continue
            candidates.append((cached_area, xcm_path, metadata))
        except Exception:
            continue

    if not candidates:
        return None

    _, xcm_path, metadata = min(candidates, key=lambda item: item[0])
    try:
        return xcm_path.read_bytes(), metadata, xcm_path
    except Exception:
        return None


def save_cached_xcm(cache_key: str, data: bytes, metadata: dict) -> None:
    TASK_MAP_XCM_CACHE_DIR.mkdir(parents=True, exist_ok=True)
    xcm_path, meta_path = xcm_cache_paths(cache_key)
    tmp_xcm = xcm_path.with_suffix(".xcm.tmp")
    tmp_meta = meta_path.with_suffix(".json.tmp")
    tmp_xcm.write_bytes(data)
    tmp_meta.write_text(
        json.dumps(metadata, ensure_ascii=False, sort_keys=True, indent=2) + "\n",
        encoding="utf-8",
    )
    os.replace(tmp_xcm, xcm_path)
    os.replace(tmp_meta, meta_path)


def prepare_cached_xcm(data: bytes, metadata: dict, cache_key: str, context: str) -> bytes:
    prepared = postprocess_task_xcm(data, context)
    if prepared != data and cache_key:
        metadata = dict(metadata)
        metadata["bytes"] = len(prepared)
        metadata["postprocessed_epoch"] = time.time()
        save_cached_xcm(cache_key, prepared, metadata)
    return prepared


def build_cache_metadata(kind: str, source_key: str, bbox, request_bbox,
                         required_bbox, tile_names, bytes_count: int,
                         runway_count: int, runway_source: str):
    return {
        "version": TASK_MAP_XCM_CACHE_VERSION,
        "kind": kind,
        "source_key": source_key,
        "bbox": bbox,
        "request_bbox": request_bbox,
        "required_bbox": required_bbox,
        "tiles": list(tile_names),
        "bytes": bytes_count,
        "runways": runway_count,
        "runway_source": runway_source,
        "created_epoch": time.time(),
    }


# ---------------------------------------------------------------------------
# Mapgen fallback — generates a new XCM from scratch when no base map covers
# the requested bbox.  Uses the XCSoar Map Generator running on the same host.
# ---------------------------------------------------------------------------

MAPGEN_URL = os.environ.get(
    "KIGO_MAPGEN_URL", "http://172.17.0.1:9091"
)
MAPGEN_TIMEOUT_S = int(os.environ.get("KIGO_MAPGEN_TIMEOUT_S", "540"))
MAPGEN_POLL_S = float(os.environ.get("KIGO_MAPGEN_POLL_S", "10"))


class _StopRedirect(urllib.request.HTTPRedirectHandler):
    """Raise HTTPError on any redirect so we can capture the Location header."""

    def redirect_request(self, req, fp, code, msg, headers, newurl):
        return None


def _mapgen_submit(bbox, name):
    """POST to mapgen and return job UUID.  Raises on failure."""
    form = {
        "name": (name or "task_map")[:80],
        "mail": "",
        "highres": "on",           # standard mapgen topology, 3 arc-second terrain
        "level_of_detail": "3",
        "selection": "bounds",
        "left":   f"{bbox['west']:.6f}",
        "right":  f"{bbox['east']:.6f}",
        "top":    f"{bbox['north']:.6f}",
        "bottom": f"{bbox['south']:.6f}",
    }
    body = urllib.parse.urlencode(form).encode("utf-8")
    req = urllib.request.Request(
        MAPGEN_URL + "/",
        data=body,
        headers={"Content-Type": "application/x-www-form-urlencoded"},
    )
    opener = urllib.request.build_opener(_StopRedirect())
    try:
        opener.open(req, timeout=30)
        raise RuntimeError("mapgen did not redirect after job submission")
    except urllib.error.HTTPError as exc:
        if exc.code not in (301, 302, 303, 307, 308):
            raise
        location = exc.headers.get("Location", "")
    # Location is e.g. "/status?uuid=abc123"
    if "uuid=" not in location:
        raise RuntimeError(f"unexpected mapgen redirect: {location!r}")
    return location.split("uuid=", 1)[1].strip()


def _mapgen_poll(uuid, timeout_s):
    """Poll mapgen /status until 'done', 'error', or timeout."""
    deadline = time.monotonic() + timeout_s
    url = f"{MAPGEN_URL}/status?uuid={uuid}"
    while time.monotonic() < deadline:
        try:
            with urllib.request.urlopen(url, timeout=20) as resp:
                html = resp.read().decode("utf-8", errors="replace")
            if "is ready to download" in html:
                return "done"
            if "Generation failed" in html or "<title>Error" in html:
                return "error"
        except Exception:
            pass
        time.sleep(MAPGEN_POLL_S)
    return "timeout"


def _xcm_has_terrain(xcm_bytes):
    """Return True if the XCM (bytes) contains a terrain.jp2 file."""
    try:
        import io
        with zipfile.ZipFile(io.BytesIO(xcm_bytes)) as zf:
            return "terrain.jp2" in zf.namelist()
    except Exception:
        return False


def _xcm_has_required_map_files(xcm_bytes):
    """Return True if the XCM has the core files Kigo needs to load it."""
    try:
        import io
        with zipfile.ZipFile(io.BytesIO(xcm_bytes)) as zf:
            names = set(zf.namelist())
    except Exception:
        return False

    return {"terrain.jp2", "terrain.j2w", "topology.tpl"}.issubset(names)


def generate_map_from_mapgen(bbox, name, runway_features=None):
    """Generate a new XCM map via mapgen, inject runways, return bytes or None."""
    try:
        uuid = _mapgen_submit(bbox, name)
    except Exception as exc:
        print(f"[mapgen] submit failed: {exc}", file=sys.stderr, flush=True)
        return None, f"mapgen submit error: {exc}"

    print(
        f"[mapgen] submitted name={name!r} uuid={uuid} bbox={bbox['south']:.4f},"
        f"{bbox['west']:.4f},{bbox['north']:.4f},{bbox['east']:.4f}",
        file=sys.stderr, flush=True,
    )

    status = _mapgen_poll(uuid, MAPGEN_TIMEOUT_S)
    if status != "done":
        print(f"[mapgen] job {uuid} ended: {status}", file=sys.stderr, flush=True)
        return None, f"mapgen {status}"

    # Download the generated XCM
    try:
        with urllib.request.urlopen(
            f"{MAPGEN_URL}/download?uuid={uuid}", timeout=120
        ) as resp:
            raw = resp.read()
    except Exception as exc:
        print(f"[mapgen] download failed {uuid}: {exc}", file=sys.stderr, flush=True)
        return None, f"mapgen download error: {exc}"

    if not _xcm_has_required_map_files(raw):
        print(
            f"[mapgen] generated incomplete XCM {uuid} (missing terrain/topology)",
            file=sys.stderr,
            flush=True,
        )
        return None, "mapgen generated incomplete XCM"

    # Inject runway polygons into topology if available.
    if runway_features and _xcm_has_terrain(raw):
        try:
            with tempfile.TemporaryDirectory(prefix="kigo_mapgen_rw_") as tmp:
                src = Path(tmp) / "base.xcm"
                dst = Path(tmp) / "out.xcm"
                src.write_bytes(raw)
                crop.crop_xcm_to_bbox(
                    src, bbox, dst,
                    excluded_vector_stems=TASK_MAP_EXCLUDED_VECTOR_STEMS,
                    forced_topology_rows=TASK_MAP_FORCED_TOPOLOGY_ROWS,
                    extra_polyline_layers=runway_polyline_layers(runway_features),
                    extra_polygon_layers=runway_polygon_layers(runway_features),
                    skip_terrain_crop=True,
                )
                raw = dst.read_bytes()
        except Exception as exc:
            print(
                f"[mapgen] runway injection failed (returning plain map): {exc}",
                file=sys.stderr, flush=True,
            )

    raw = postprocess_task_xcm(raw, "mapgen")

    print(f"[mapgen] done name={name!r} uuid={uuid} bytes={len(raw)}", file=sys.stderr, flush=True)
    return raw, ""


def generate_map_from_base(base_map: BaseMap, bbox, runway_features=None):
    """Crop a POL_HighRes-style base XCM and inject runway layers."""
    try:
        with tempfile.TemporaryDirectory(prefix="kigo_base_crop_") as tmp:
            dst = Path(tmp) / "task_map.xcm"
            crop.crop_xcm_to_bbox(
                base_map.path,
                bbox,
                dst,
                excluded_vector_stems=TASK_MAP_EXCLUDED_VECTOR_STEMS,
                forced_topology_rows=TASK_MAP_FORCED_TOPOLOGY_ROWS,
                extra_polyline_layers=runway_polyline_layers(runway_features or ()),
                extra_polygon_layers=runway_polygon_layers(runway_features or ()),
            )
            raw = dst.read_bytes()
    except Exception as exc:
        print(
            f"[base-map] crop failed base={base_map.path}: {exc}",
            file=sys.stderr,
            flush=True,
        )
        return None, f"base map crop error: {exc}"

    raw = postprocess_task_xcm(raw, "base-map")

    print(
        f"[base-map] cropped base={base_map.path.name} bbox={bbox['south']:.4f},"
        f"{bbox['west']:.4f},{bbox['north']:.4f},{bbox['east']:.4f} bytes={len(raw)}",
        file=sys.stderr,
        flush=True,
    )
    return raw, ""


class TaskMapHandler(BaseHTTPRequestHandler):
    server_version = "KigoTaskMapHTTP/1.0"
    base_maps: tuple[BaseMap, ...]

    def send_text(self, status: int, message: str):
        body = (message.rstrip() + "\n").encode("utf-8", errors="replace")
        self.send_response(status)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def send_xcm(self, data: bytes, *, bbox, task_name: str, map_name: str,
                 task_points, runway_features, runway_source: str,
                 runway_error: str, map_source: str, cache_status: str,
                 cache_key: str = "", tile_names=()):
        self.send_response(200)
        self.send_header("Content-Type", "application/octet-stream")
        self.send_header("Content-Disposition", "attachment; filename=task_map_30km.xcm")
        self.send_header("Content-Length", str(len(data)))
        self.send_header("X-Kigo-Bbox", bbox_header_text(bbox))
        self.send_header("X-Kigo-Base-Map", map_source)
        self.send_header("X-Kigo-Map-Source", map_source)
        self.send_header("X-Kigo-Map-Name", map_name)
        self.send_header("X-Kigo-Task-Points", str(len(task_points)))
        self.send_header("X-Kigo-Runways", str(len(runway_features or ())))
        self.send_header("X-Kigo-Runway-Source", runway_source)
        self.send_header("X-Kigo-Cache", cache_status)
        if cache_key:
            self.send_header("X-Kigo-Cache-Key", cache_key[:40])
        if tile_names:
            self.send_header("X-Kigo-Source-Tiles", ",".join(tile_names))
        if runway_error:
            self.send_header("X-Kigo-Runway-Error", runway_error[:200])
        self.end_headers()
        self.wfile.write(data)
        self.log_message(
            "task-map generated task=%r map_name=%r source=%s cache=%s points=%d runways=%d runway_source=%s runway_error=%r bbox=%s bytes=%d tiles=%s",
            task_name,
            map_name,
            map_source,
            cache_status,
            len(task_points),
            len(runway_features or ()),
            runway_source,
            runway_error,
            bbox_header_text(bbox),
            len(data),
            ",".join(tile_names),
        )

    def do_GET(self):
        if self.path == "/health":
            self.send_text(200, "ok")
        else:
            self.send_text(404, "not found")

    def do_POST(self):
        if self.path != "/api/task-map":
            self.send_text(404, "not found")
            return

        try:
            length = int(self.headers.get("Content-Length", "0"))
        except ValueError:
            self.send_text(400, "invalid Content-Length")
            return

        if length <= 0 or length > 1024 * 1024:
            self.send_text(413, "invalid request size")
            return

        try:
            payload = json.loads(self.rfile.read(length).decode("utf-8"))
            if not isinstance(payload, dict):
                raise ValueError("payload must be a JSON object")
            bbox = bbox_from_payload(payload)
            validate_bbox(bbox)
            task_points = task_points_from_payload(payload)
            required_bbox = route_cache_bbox(payload, bbox, task_points)
            validate_bbox(required_bbox)
        except Exception as exc:
            self.send_text(400, f"bad task map request: {exc}")
            return

        bbox_header = bbox_header_text(bbox)
        task_name = str(payload.get("task_name") or "task_map")
        map_name = f"{task_name}_gen"
        self.log_message(
            "task-map request task=%r map_name=%r bbox=%s required_bbox=%s points=%s",
            task_name,
            map_name,
            bbox_header,
            bbox_header_text(required_bbox),
            payload_points_summary(payload),
        )

        source_key = source_repo_fingerprint()
        cached = find_covering_cached_xcm(required_bbox, source_key)
        if cached is not None:
            data, metadata, _ = cached
            data = prepare_cached_xcm(
                data,
                metadata,
                str(metadata.get("cache_key") or ""),
                "xcm-cache",
            )
            cached_bbox = metadata.get("bbox") if isinstance(metadata.get("bbox"), dict) else bbox
            self.send_xcm(
                data,
                bbox=cached_bbox,
                task_name=task_name,
                map_name=map_name,
                task_points=task_points,
                runway_features=[None] * int(metadata.get("runways") or 0),
                runway_source=str(metadata.get("runway_source") or "cache"),
                runway_error="",
                map_source="xcm-cache",
                cache_status="hit",
                cache_key=str(metadata.get("cache_key") or ""),
                tile_names=metadata.get("tiles") or (),
            )
            return

        try:
            base_map = select_base_map(self.base_maps, bbox)
        except Exception as exc:
            self.log_message(
                "base-map crop unavailable task=%r bbox=%s error=%r; falling back to mapgen",
                task_name,
                bbox_header_text(bbox),
                str(exc),
            )
        else:
            base_tile_name = base_map.path.name
            cache_key = xcm_cache_digest(
                "base-crop",
                source_key,
                bbox,
                (base_tile_name,),
            )
            cached = read_cached_xcm(cache_key)
            if cached is not None:
                data, metadata, _ = cached
                data = prepare_cached_xcm(data, metadata, cache_key, "xcm-cache")
                self.send_xcm(
                    data,
                    bbox=bbox,
                    task_name=task_name,
                    map_name=map_name,
                    task_points=task_points,
                    runway_features=[None] * int(metadata.get("runways") or 0),
                    runway_source=str(metadata.get("runway_source") or "cache"),
                    runway_error="",
                    map_source="xcm-cache",
                    cache_status="base-hit",
                    cache_key=cache_key,
                    tile_names=(base_tile_name,),
                )
                return

            try:
                runway_features, runway_error, runway_source = fetch_osm_runways(bbox)
            except Exception as exc:
                runway_features = []
                runway_error = str(exc)
                runway_source = "none"

            data, base_error = generate_map_from_base(
                base_map,
                bbox,
                runway_features=runway_features,
            )
            if data is not None:
                metadata = build_cache_metadata(
                    "base-crop",
                    source_key,
                    bbox,
                    bbox,
                    required_bbox,
                    (base_tile_name,),
                    len(data),
                    len(runway_features),
                    runway_source,
                )
                metadata["cache_key"] = cache_key
                save_cached_xcm(cache_key, data, metadata)
                self.send_xcm(
                    data,
                    bbox=bbox,
                    task_name=task_name,
                    map_name=map_name,
                    task_points=task_points,
                    runway_features=runway_features,
                    runway_source=runway_source,
                    runway_error=runway_error,
                    map_source=f"base-crop:{base_tile_name}",
                    cache_status="base-miss-filled",
                    cache_key=cache_key,
                    tile_names=(base_tile_name,),
                )
                return

            self.log_message(
                "base-map crop failed task=%r base=%s error=%r; falling back to mapgen",
                task_name,
                base_tile_name,
                base_error,
            )

        tile_cache = select_source_tile_cache(required_bbox)
        if tile_cache is not None:
            tiles, cache_bbox = tile_cache
            tile_names = tuple(tile.name for tile in tiles)
            cache_key = xcm_cache_digest("source-tiles", source_key, cache_bbox, tile_names)
            cached = read_cached_xcm(cache_key)
            if cached is not None:
                data, metadata, _ = cached
                data = prepare_cached_xcm(data, metadata, cache_key, "xcm-cache")
                self.send_xcm(
                    data,
                    bbox=cache_bbox,
                    task_name=task_name,
                    map_name=map_name,
                    task_points=task_points,
                    runway_features=[None] * int(metadata.get("runways") or 0),
                    runway_source=str(metadata.get("runway_source") or "cache"),
                    runway_error="",
                    map_source="xcm-cache",
                    cache_status="hit",
                    cache_key=cache_key,
                    tile_names=tile_names,
                )
                return

            try:
                runway_features, runway_error, runway_source = fetch_osm_runways(cache_bbox)
            except Exception as exc:
                runway_features = []
                runway_error = str(exc)
                runway_source = "none"

            data, mapgen_error = generate_map_from_mapgen(
                cache_bbox,
                "tiles_" + "_".join(name.rsplit("/", 1)[-1] for name in tile_names),
                runway_features=runway_features,
            )
            if data is None:
                self.log_message(
                    "tile-cache generation failed task=%r tiles=%s error=%r; falling back to exact bbox",
                    task_name,
                    ",".join(tile_names),
                    mapgen_error,
                )
            else:
                metadata = build_cache_metadata(
                    "source-tiles",
                    source_key,
                    cache_bbox,
                    bbox,
                    required_bbox,
                    tile_names,
                    len(data),
                    len(runway_features),
                    runway_source,
                )
                metadata["cache_key"] = cache_key
                save_cached_xcm(cache_key, data, metadata)
                self.send_xcm(
                    data,
                    bbox=cache_bbox,
                    task_name=task_name,
                    map_name=map_name,
                    task_points=task_points,
                    runway_features=runway_features,
                    runway_source=runway_source,
                    runway_error=runway_error,
                    map_source="mapgen-source-tiles",
                    cache_status="miss-filled",
                    cache_key=cache_key,
                    tile_names=tile_names,
                )
                return

        exact_key = xcm_cache_digest("exact-bbox", source_key, bbox)
        cached = read_cached_xcm(exact_key)
        if cached is not None:
            data, metadata, _ = cached
            data = prepare_cached_xcm(data, metadata, exact_key, "xcm-cache")
            self.send_xcm(
                data,
                bbox=bbox,
                task_name=task_name,
                map_name=map_name,
                task_points=task_points,
                runway_features=[None] * int(metadata.get("runways") or 0),
                runway_source=str(metadata.get("runway_source") or "cache"),
                runway_error="",
                map_source="xcm-cache",
                cache_status="exact-hit",
                cache_key=exact_key,
            )
            return

        try:
            runway_features, runway_error, runway_source = fetch_osm_runways(bbox)
        except Exception as exc:
            runway_features = []
            runway_error = str(exc)
            runway_source = "none"

        data, mapgen_error = generate_map_from_mapgen(
            bbox,
            map_name,
            runway_features=runway_features,
        )
        if data is None:
            self.send_text(500, f"task map failed: {mapgen_error}")
            return

        metadata = build_cache_metadata(
            "exact-bbox",
            source_key,
            bbox,
            bbox,
            required_bbox,
            (),
            len(data),
            len(runway_features),
            runway_source,
        )
        metadata["cache_key"] = exact_key
        save_cached_xcm(exact_key, data, metadata)
        self.send_xcm(
            data,
            bbox=bbox,
            task_name=task_name,
            map_name=map_name,
            task_points=task_points,
            runway_features=runway_features,
            runway_source=runway_source,
            runway_error=runway_error,
            map_source="mapgen",
            cache_status="exact-miss-filled",
            cache_key=exact_key,
        )


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--host", default=os.environ.get("KIGO_TASK_MAP_HOST", "0.0.0.0"))
    parser.add_argument(
        "--port",
        type=int,
        default=int(os.environ.get("KIGO_TASK_MAP_PORT", "8787")),
    )
    parser.add_argument("--base-xcm", type=Path)
    args = parser.parse_args()

    TaskMapHandler.base_maps = find_base_maps(args.base_xcm)
    server = ThreadingHTTPServer((args.host, args.port), TaskMapHandler)
    print(
        f"Kigo task map service listening on {args.host}:{args.port}; "
        "bases=" + ", ".join(str(base.path) for base in TaskMapHandler.base_maps),
        flush=True,
    )
    server.serve_forever()


if __name__ == "__main__":
    main()
