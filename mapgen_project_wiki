'import time; from xcsoar.mapgen.server.worker import Worker; Bounds = type("Bounds", (), {"left": 19.0, "right": 20.0, "top": 50.0, "bottom": 49.0}); Description = type("Description", (), {"name": "smoke", "bounds": Bounds()}); Job = type("Job", (), {"uuid": "smoke-uuid", "description": Description()}); worker = Worker("/tmp", "/tmp", ""); worker._Worker__log_job_metrics(Job(), time.monotonic() - 2.5, "done")'
```

